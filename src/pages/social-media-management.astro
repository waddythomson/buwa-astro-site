---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const faq = [
  {
    question: "How often will you post on my social media accounts?",
    answer: "Posting frequency depends on your plan and platform mix, but most of our clients see the best results with 3–5 posts per week across their primary platforms. We build a custom content calendar each month that balances promotional content, educational posts, community engagement, and trending topics — so your audience stays engaged without feeling overwhelmed.",
  },
  {
    question: "Which social media platforms should my business be on?",
    answer: "It depends on your audience and industry. Facebook and Instagram are strong for most local businesses in the Midlands. LinkedIn is essential for B2B and professional services. TikTok is growing fast for brands that want to reach younger demographics with short-form video. During our discovery phase, we'll audit your audience and recommend the platforms where your time and budget will have the most impact.",
  },
  {
    question: "Can I still post on my own accounts while you manage them?",
    answer: "Absolutely. We encourage it — authentic, in-the-moment content from business owners performs well alongside our planned content. We'll coordinate with you so nothing overlaps or conflicts. Most clients find that once we handle the heavy lifting of strategy and scheduling, they enjoy posting occasional behind-the-scenes updates on their own terms.",
  },
  {
    question: "How do you measure success with social media management?",
    answer: "We track engagement rate, follower growth, reach, impressions, website clicks, and conversions monthly. You'll receive a clear performance report showing what's working and where we're adjusting. We also benchmark against industry averages so you can see exactly how your accounts stack up against competitors in the Midlands.",
  },
  {
    question: "How long before I start seeing results?",
    answer: "Social media is a long-game strategy, but most businesses begin seeing meaningful engagement improvements within 60–90 days. Brand awareness and community growth build momentum over time — the businesses that commit to consistent, quality content for 6+ months see the strongest returns in lead generation and customer loyalty.",
  },
];

const relatedServices = [
  { label: "Social Media Ads", href: "/social-media-ads/" },
  { label: "Google Business Profile", href: "/google-business-profile/" },
  { label: "Website Design", href: "/website-design/" },
  { label: "Design Services", href: "/design/" },
];
---

<BaseLayout 
  title="Social Media Management | BuWa Digital - The Midlands"
  description="Professional social media management for Midlands businesses. Content creation, scheduling, community engagement, and strategy across Facebook, Instagram, LinkedIn, TikTok & more."
  faq={faq}
  hasTopHero={true}
>
  <!-- Hero Section -->
  <PageHero
    title="Social Media Management"
    subtitle="Is Your Brand Showing Up — or Getting Scrolled Past?"
    description="Your customers are on social media every day. Professional social media management ensures your business stays visible, builds trust, and turns followers into loyal customers — with consistent, high-quality content that actually gets results."
  >
    <a href="/contact-us/" class="btn-red">Let's Talk!</a>
  </PageHero>

  <!-- Intro Section — WHITE -->
  <section class="intro-section">
    <div class="container">
      <h2>Your Brand Deserves Better Than Silence</h2>
      <p class="intro-text">An inconsistent or inactive social media presence tells potential customers your business doesn't care — or worse, isn't around anymore. Strategic social media management keeps your brand front and center, builds authentic connections with your community, and creates a steady pipeline of engagement that drives real business results. We handle the content, the scheduling, and the conversations so you can focus on running your business.</p>
    </div>
  </section>

  <!-- Why Social Media Management — VIDEO BG -->
  <section class="animated-bg-section">
  <div class="container section-content">
      <h2>Why Professional Social Media Management?</h2>
      
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">⏰</div>
          <div class="benefit-content">
            <h3>Save Hours Every Week</h3>
            <p>Creating content, writing captions, scheduling posts, and responding to comments eats up 6–10 hours a week. We take that off your plate entirely so you can focus on your customers and operations.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🎨</div>
          <div class="benefit-content">
            <h3>Professional Quality</h3>
            <p>No more blurry photos or rushed captions. Every post is crafted with professional graphics, compelling copy, and a cohesive brand voice that builds credibility with your audience.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">📅</div>
          <div class="benefit-content">
            <h3>Rock-Solid Consistency</h3>
            <p>The algorithm rewards brands that show up regularly. We maintain a strategic posting schedule that keeps your audience engaged and your content in their feeds — week after week, month after month.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">📍</div>
          <div class="benefit-content">
            <h3>Midlands Expertise</h3>
            <p>We know the Midlands — Lexington, Irmo, West Columbia, Red Bank, and beyond. Our content resonates locally because we understand what matters to your neighbors and customers right here.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Numbers — WHITE -->
  <section class="stats-section">
    <div class="container">
      <h2>Social Media By the Numbers</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">77%</div>
          <div class="stat-label">of consumers are more likely to buy from brands they follow on social media</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">90%</div>
          <div class="stat-label">of Instagram users follow at least one business account</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">2.5h</div>
          <div class="stat-label">average daily time spent on social media per person in the U.S.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works — VIDEO BG -->
  <section class="animated-bg-section">
  <div class="container section-content">
      <h2>How It Works</h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Brand Audit</h3>
            <p>We review your current social presence, competitors, and audience to identify gaps and opportunities for growth.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Content Planning</h3>
            <p>We build a monthly content calendar with a strategic mix of posts — promotional, educational, community-driven, and trend-based.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Create & Publish</h3>
            <p>Our team designs graphics, writes captions, and schedules posts across your platforms — all approved by you before going live.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Engage & Optimize</h3>
            <p>We monitor comments and messages, engage with your audience, and refine strategy monthly based on performance data.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach — WHITE -->
  <section class="approach-section">
    <div class="container">
      <h2>Our Approach</h2>
      <p class="approach-intro">Every social media management engagement follows our proven five-step process to drive consistent, measurable growth.</p>
      <ol class="approach-list">
        <li><strong>Discovery</strong> — We learn your brand voice, audience, goals, and competitive landscape to build a foundation that fits.</li>
        <li><strong>Strategy</strong> — We define platform priorities, content pillars, posting frequency, and engagement tactics tailored to your market.</li>
        <li><strong>Execution</strong> — We create and publish high-quality content on a consistent schedule, maintaining your brand voice across every platform.</li>
        <li><strong>Evaluation</strong> — We track engagement, reach, follower growth, and conversions to measure what's working and what needs to shift.</li>
        <li><strong>Optimization</strong> — We continuously refine content strategy, posting times, and creative direction based on real performance data.</li>
      </ol>
    </div>
  </section>

  <!-- Who It's For — VIDEO BG -->
  <section class="animated-bg-section">
  <div class="container section-content">
      <h2>Who It's For</h2>
      
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">🍽️</div>
          <div class="benefit-content">
            <h3>Restaurants & Hospitality</h3>
            <p>Showcase daily specials, behind-the-scenes kitchen moments, and customer reviews to keep tables full and your brand buzzing in the local food scene.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🏠</div>
          <div class="benefit-content">
            <h3>Home Services</h3>
            <p>Build trust with before-and-after project photos, seasonal tips, and customer testimonials that keep your HVAC, plumbing, or landscaping company top-of-mind.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">⚖️</div>
          <div class="benefit-content">
            <h3>Professional Services</h3>
            <p>Establish thought leadership on LinkedIn and Facebook with educational content, case highlights, and community involvement that builds authority for your firm.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🛍️</div>
          <div class="benefit-content">
            <h3>Retail & E-Commerce</h3>
            <p>Drive foot traffic and online sales with product showcases, promotions, user-generated content, and shoppable posts that convert followers into buyers.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ — WHITE -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faq.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">{item.question}</summary>
            <p class="faq-answer">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Services That Pair Well — VIDEO BG -->
  <section class="animated-bg-section related-section">
  <div class="container section-content">
      <h2>Services That Pair Well</h2>
      <p class="related-intro">Supercharge your social presence with these complementary strategies.</p>
      <div class="related-services">
        {relatedServices.map((service) => (
          <a href={service.href} class="related-pill">{service.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — WHITE -->
  <section class="cta-section-white">
    <div class="container">
      <h2>Ready to Own Your Social Presence?</h2>
      <p>Stop letting inconsistent posting cost you customers — let's build a social media strategy that keeps your local business growing.</p>
      <a href="/contact-us/" class="btn-red">Let's Talk!</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ==================== SHARED LAYOUT ==================== */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ==================== WHITE SECTIONS ==================== */
  .intro-section,
  .stats-section,
  .approach-section,
  .faq-section,
  .cta-section-white {
    padding: 5rem 0;
    background: #ffffff;
    color: #1a1a2e;
  }

  .intro-section h2,
  .stats-section h2,
  .approach-section h2,
  .faq-section h2,
  .cta-section-white h2 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin-bottom: 1.5rem;
    text-align: center;
    color: #0c1e43;
  }

  .intro-text {
    font-size: 1.15rem;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    color: #444;
  }

  /* ==================== VIDEO BG SECTIONS ==================== */
  .video-bg-section {
    position: relative;
    padding: 5rem 0;
    overflow: hidden;
  }

  .section-video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 0;
  }

  .section-video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 15, 20, 0.55);
    z-index: 1;
  }

  .section-content {
    position: relative;
    z-index: 2;
  }

  .video-bg-section h2 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin-bottom: 2rem;
    text-align: center;
    color: #ffffff;
  }

  /* ==================== BENEFITS / CARDS GRID ==================== */
  .benefits-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .benefits-grid > * {
    flex: 0 1 calc(33.333% - 1rem);
    min-width: 260px;
  }

  .benefit-card {
    background: rgba(30, 30, 35, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .benefit-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .benefit-card h3 {
    color: #ffffff;
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .benefit-card p {
    color: rgba(210, 232, 255, 0.85);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ==================== STATS ==================== */
  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .stats-grid > * {
    flex: 0 1 calc(33.333% - 1rem);
    min-width: 220px;
  }

  .stat-card {
    background: #f0f4f8;
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .stat-number {
    font-size: 2.8rem;
    font-weight: 700;
    color: #0c1e43;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.5;
  }

  /* ==================== PROCESS STEPS ==================== */
  .process-steps {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 1 calc(25% - 1.2rem);
    min-width: 200px;
    background: rgba(30, 30, 35, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .step-number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e63946, #c1121f);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .step-content h3 {
    color: #ffffff;
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }

  .step-content p {
    color: rgba(210, 232, 255, 0.85);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ==================== APPROACH ==================== */
  .approach-intro {
    text-align: center;
    color: #555;
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .approach-list {
    max-width: 800px;
    margin: 0 auto;
    padding-left: 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .approach-list li {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #333;
  }

  .approach-list li strong {
    color: #0c1e43;
  }

  /* ==================== FAQ ==================== */
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    background: #f0f4f8;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
  }

  .faq-question {
    font-weight: 600;
    font-size: 1.05rem;
    color: #0c1e43;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-question::after {
    content: "+";
    font-size: 1.3rem;
    font-weight: 300;
    color: #888;
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-question::after {
    content: "−";
  }

  .faq-answer {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #555;
  }

  /* ==================== RELATED SERVICES ==================== */
  .related-intro {
    text-align: center;
    color: rgba(210, 232, 255, 0.85);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .related-services {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .related-pill {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .related-pill:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #ffffff;
  }

  /* ==================== WHITE CTA ==================== */
  .cta-section-white {
    text-align: center;
    padding: 5rem 0;
  }

  .cta-section-white p {
    font-size: 1.15rem;
    color: #555;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ==================== BUTTON ==================== */
  .btn-red {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    background: linear-gradient(135deg, #e63946, #c1121f);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 50px;
    text-decoration: none;
    border: 2px solid #b82232;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-red:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(230, 57, 70, 0.4);
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
