---
import BaseLayout from '../../layouts/buwatv/BaseLayout.astro';
import BuWaTvSiteHeader from '../../components/buwatv/BuWaTvSiteHeader.astro';
---

<BaseLayout 
  title="About BuWa TV | Indoor Digital Billboard Advertising in the Midlands"
  description="BuWa TV helps local Midlands businesses grow through affordable indoor digital billboard advertising. Learn about our mission to strengthen the local business community."
>
  <BuWaTvSiteHeader slot="header" />

  <!-- Hero Section -->
  <section class="page-hero">
    <div class="container">
      <h1>About BuWa TV</h1>
      <p class="hero-subtitle">Helping Midlands businesses be seen, trusted, and chosen.</p>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="mission-section">
    <div class="container">
      <div class="mission-content">
        <div class="mission-text">
          <h2>Our Mission</h2>
          <p class="mission-statement">To strengthen the local business community by providing affordable, high-impact advertising that delivers real results.</p>
        </div>
        <div class="mission-icon">
          <i class="fas fa-bullseye"></i>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="story-section">
    <div class="container">
      <h2>Our Story</h2>
      <div class="story-content">
        <p class="story-text">BuWa was built on one idea: <strong>strengthen local</strong>. Buck and Waddy believe that when local businesses connect with their community and each other, everyone wins.</p>
      </div>
    </div>
  </section>

  <!-- What We Believe Section -->
  <section class="beliefs-section">
    <div class="container">
      <h2>What We Believe</h2>
      <div class="belief-card">
        <p class="belief-text"><strong>Local isn't just our market — it's our mission.</strong></p>
        <p>We're here to help local businesses support each other, reach more neighbors, and build something stronger together. When you grow, the community grows with you.</p>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="container">
      <h2>BuWa TV by the Numbers</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">50+</div>
          <div class="stat-label">Screens Across the Midlands</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">1000s</div>
          <div class="stat-label">Daily Impressions</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">100%</div>
          <div class="stat-label">Locally Focused</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Indoor Digital Section -->
  <section class="why-section">
    <div class="container">
      <h2>Why Indoor Digital Billboards?</h2>
      <div class="why-content">
        <p>Traditional advertising is expensive and often misses the mark. Social media is crowded and algorithm-driven. BuWa TV puts your business in front of real people in real places — where they eat, shop, work, and play.</p>
        <div class="stats-highlight">
          <div class="highlight-item">
            <span class="highlight-number">400%</span>
            <span class="highlight-text">more impactful than static advertising</span>
          </div>
          <div class="highlight-item">
            <span class="highlight-number">83%</span>
            <span class="highlight-text">recall among consumers</span>
          </div>
          <div class="highlight-item">
            <span class="highlight-number">30%</span>
            <span class="highlight-text">increase in average ticket value</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials-section">
    <div class="container">
      <h2>What Our Partners Say</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-content">
            <i class="fas fa-quote-left quote-icon"></i>
            <p>"The team at BuWa Digital has been amazing to work with. They truly understand B2B advertising and have helped us reach new businesses in the community."</p>
          </div>
          <div class="testimonial-author">
            <strong>Christina Nelson</strong>
            <span>Greater CWC Chamber of Commerce</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-content">
            <i class="fas fa-quote-left quote-icon"></i>
            <p>"BuWa Digital is the real deal. They don't just provide a service — they become a true partner in your success."</p>
          </div>
          <div class="testimonial-author">
            <strong>David Medley</strong>
            <span>Better Homes and Gardens Real Estate</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-content">
            <i class="fas fa-quote-left quote-icon"></i>
            <p>"The Google Business Profile work they did for us was outstanding. We've seen a real increase in visibility and customer inquiries."</p>
          </div>
          <div class="testimonial-author">
            <strong>Zach Coggins</strong>
            <span>Milestone Wealth Advisors</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Strengthen Your Local Presence?</h2>
      <p>Join the BuWa TV network and connect with your community.</p>
      <div class="cta-buttons">
        <a href="/buwatv/signup/" class="btn btn-red">
          <i class="fas fa-user-plus"></i> Get Started
        </a>
        <a href="/buwatv/pricing/" class="btn btn-white">
          <i class="fas fa-dollar-sign"></i> View Pricing
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    background: transparent;
    color: #fff;
    padding: 140px 20px 80px;
    text-align: center;
  }

  .page-hero h1 {
    font-family: 'Outfit', 'Inter', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 15px;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: rgba(232, 242, 255, 0.92);
    max-width: 600px;
    margin: 0 auto;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.4);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    text-decoration: none;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 7px 14px rgba(0,0,0,0.15);
  }

  .btn-red {
    background: linear-gradient(to bottom, #b82232, #a01c2b);
    color: white;
  }

  .btn-white {
    background: linear-gradient(to bottom, #ffffff, #f0f0f0);
    color: #17246c;
  }

  /* Mission Section */
  .mission-section {
    padding: 80px 0;
    background: transparent;
  }

  .mission-content {
    display: flex;
    align-items: center;
    gap: 60px;
    max-width: 900px;
    margin: 0 auto;
    background: #fff;
    border-radius: 16px;
    padding: 48px 44px;
    border: 1px solid rgba(23, 36, 108, 0.08);
    box-shadow:
      0 10px 40px rgba(0, 0, 0, 0.12),
      0 2px 10px rgba(0, 0, 0, 0.06);
  }

  .mission-text h2 {
    font-size: 2rem;
    color: #17246c;
    margin-bottom: 20px;
  }

  .mission-statement {
    font-size: 1.3rem;
    color: #444;
    line-height: 1.7;
  }

  .mission-icon {
    flex-shrink: 0;
  }

  .mission-icon i {
    font-size: 6rem;
    color: #a01c2b;
    opacity: 0.8;
  }

  /* Story Section */
  .story-section {
    padding: 80px 0;
    background: transparent;
  }

  .story-section h2 {
    text-align: center;
    font-size: 2rem;
    font-family: 'Outfit', 'Inter', sans-serif;
    color: #e8f2ff;
    margin-bottom: 40px;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .story-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    background: #fff;
    border-radius: 16px;
    padding: 40px 36px;
    border: 1px solid rgba(23, 36, 108, 0.08);
    box-shadow:
      0 10px 40px rgba(0, 0, 0, 0.12),
      0 2px 10px rgba(0, 0, 0, 0.06);
  }

  .story-text {
    font-size: 1.25rem;
    color: #444;
    line-height: 1.8;
  }

  /* Beliefs Section */
  .beliefs-section {
    padding: 80px 0;
    background: transparent;
  }

  .beliefs-section h2 {
    text-align: center;
    font-size: 2rem;
    font-family: 'Outfit', 'Inter', sans-serif;
    color: #e8f2ff;
    margin-bottom: 40px;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .belief-card {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    padding: 40px;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    text-align: center;
  }

  .belief-text {
    font-size: 1.3rem;
    color: #17246c;
    margin-bottom: 15px;
  }

  .belief-card p {
    font-size: 1.1rem;
    color: #555;
    line-height: 1.7;
  }

  /* Stats Section */
  .stats-section {
    padding: 80px 0;
    background: transparent;
    color: #e8f2ff;
  }

  .stats-section h2 {
    text-align: center;
    font-size: 2rem;
    font-family: 'Outfit', 'Inter', sans-serif;
    margin-bottom: 50px;
    color: #e8f2ff;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }

  .stat-card {
    text-align: center;
    background: rgba(30, 30, 35, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    padding: 36px 24px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.24);
  }

  .stat-number {
    font-size: 3.5rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 10px;
  }

  .stat-label {
    font-size: 1rem;
    color: rgba(232, 242, 255, 0.88);
  }

  /* Why Section */
  .why-section {
    padding: 80px 0;
    background: transparent;
  }

  .why-section h2 {
    text-align: center;
    font-size: 2rem;
    font-family: 'Outfit', 'Inter', sans-serif;
    color: #e8f2ff;
    margin-bottom: 30px;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .why-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    background: #fff;
    border-radius: 16px;
    padding: 40px 36px 48px;
    border: 1px solid rgba(23, 36, 108, 0.08);
    box-shadow:
      0 10px 40px rgba(0, 0, 0, 0.12),
      0 2px 10px rgba(0, 0, 0, 0.06);
  }

  .why-content > p {
    font-size: 1.1rem;
    color: #555;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .stats-highlight {
    display: flex;
    justify-content: center;
    gap: 50px;
    flex-wrap: wrap;
  }

  .highlight-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .highlight-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #a01c2b;
  }

  .highlight-text {
    font-size: 0.9rem;
    color: #666;
    max-width: 150px;
  }

  /* Testimonials Section */
  .testimonials-section {
    padding: 80px 0;
    background: transparent;
  }

  .testimonials-section h2 {
    text-align: center;
    font-size: 2rem;
    font-family: 'Outfit', 'Inter', sans-serif;
    color: #e8f2ff;
    margin-bottom: 50px;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .testimonial-card {
    background: white;
    padding: 35px;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
  }

  .quote-icon {
    color: #a01c2b;
    font-size: 1.5rem;
    margin-bottom: 15px;
  }

  .testimonial-content p {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    font-style: italic;
  }

  .testimonial-author {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #eee;
  }

  .testimonial-author strong {
    display: block;
    color: #17246c;
    font-size: 1rem;
  }

  .testimonial-author span {
    font-size: 0.85rem;
    color: #888;
  }

  /* CTA Section */
  .cta-section {
    padding: 80px 0;
    background: transparent;
    color: #e8f2ff;
    text-align: center;
  }

  .cta-section .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 36px;
    background: rgba(30, 30, 35, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.24);
  }

  .cta-section h2 {
    font-size: 2.2rem;
    margin-bottom: 15px;
    color: #fff;
  }

  .cta-section > .container > p {
    font-size: 1.1rem;
    color: rgba(232, 242, 255, 0.9);
    margin-bottom: 30px;
  }

  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .mission-content {
      flex-direction: column;
      text-align: center;
    }

    .stats-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .stats-highlight {
      flex-direction: column;
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 120px 20px 60px;
    }

    .mission-icon i {
      font-size: 4rem;
    }

    .stat-number {
      font-size: 2.5rem;
    }
  }
</style>