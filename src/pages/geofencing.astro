---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const faq = [
  {
    question: "Will display advertising and geofencing help generate leads?",
    answer: "Display advertising with geofencing is primarily a brand awareness and top-of-funnel strategy. While it can drive website visits and conversions, its greatest strength is keeping your brand front-and-center with audiences in specific locations. Over time, this awareness translates into more branded searches, higher click-through rates on other campaigns, and stronger lead generation across your entire marketing mix.",
  },
  {
    question: "Can you geofence any location?",
    answer: "We can geofence most commercial locations, event venues, competitor storefronts, and public spaces. However, there are restrictions — sensitive locations such as schools (K-12), medical facilities, places of worship, and government buildings are off-limits per industry compliance standards. We'll work with you to identify the highest-impact locations that align with your goals and stay within guidelines.",
  },
  {
    question: "Can you target specific phone numbers or people?",
    answer: "No — geofencing targets device IDs based on physical location, not individual phone numbers or personal identities. When a mobile device enters your geofenced area, that device ID is captured anonymously. This allows us to serve ads to that device later across websites and apps without ever collecting personal information, keeping your campaigns both effective and privacy-compliant.",
  },
  {
    question: "How do I know if display advertising is right for my business?",
    answer: "If your business benefits from local visibility — think retail, restaurants, professional services, real estate, or events — display advertising with geofencing is a powerful fit. It's especially effective when you want to reach people near your location or your competitors' locations. We'll evaluate your goals, audience, and market during a free consultation to determine whether display fits into your overall strategy.",
  },
  {
    question: "How long does it take to see results from a geofencing campaign?",
    answer: "Most campaigns begin delivering impressions within 24–48 hours of launch. However, the real impact of display advertising builds over time — typically 30 to 90 days — as your brand gains repeated exposure with your target audience. We provide regular reporting so you can track impressions, click-through rates, and audience reach from day one.",
  },
];

const relatedServices = [
  { label: "Connected TV/OTT", href: "/connected-tv-ott-ads/" },
  { label: "Social Media Ads", href: "/social-media-ads/" },
  { label: "PPC", href: "/pay-per-click-ppc/" },
  { label: "Pre-Roll Advertising", href: "/pre-roll-advertising/" },
];
---

<BaseLayout 
  title="Display Advertising & Geofencing | BuWa Digital - The Midlands"
  description="Target customers by location with display advertising and geofencing across the Midlands. BuWa Digital delivers precision-targeted ads on the websites your audience visits most."
  faq={faq}
  hasTopHero={true}
>
  <!-- Hero Section -->
  <PageHero
    title="Display Advertising & Geofencing"
    subtitle="What If You Could Follow Your Ideal Customer — Wherever They Browse?"
    description="Geofencing technology lets you draw a virtual boundary around any location and serve dynamic display ads to the people who visit. Reach your audience on the websites and apps they use most — with precision targeting that traditional advertising simply can't match."
  >
    <a href="/contact-us/" class="btn-red">Let's Talk!</a>
  </PageHero>

  <!-- Intro Section — WHITE -->
  <section class="intro-section">
    <div class="container">
      <h2>Location-Powered Advertising That Works</h2>
      <p class="intro-text">Display advertising with geofencing combines the visual impact of banner and rich-media ads with the precision of location-based targeting. Draw a virtual fence around competitor locations, event venues, shopping centers, or entire neighborhoods — then serve your branded ads to those audiences as they browse their favorite websites and apps. It's brand awareness with surgical precision.</p>
    </div>
  </section>

  <!-- Why Geofencing — VIDEO BG -->
  <section class="animated-bg-section">
  <div class="container section-content">
      <h2>Why Display & Geofencing?</h2>
      
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">📍</div>
          <div class="benefit-content">
            <h3>Precision Targeting</h3>
            <p>Draw virtual boundaries around any location — competitor storefronts, event venues, neighborhoods — and reach the devices that enter those zones with your ads.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🔔</div>
          <div class="benefit-content">
            <h3>Brand Awareness at Scale</h3>
            <p>Your full-motion, dynamic ads appear across thousands of premium websites and apps, building recognition with your ideal audience every time they browse.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🏆</div>
          <div class="benefit-content">
            <h3>Competitive Advantage</h3>
            <p>Geofence your competitors' locations and serve your ads to their customers. Intercept shoppers right when they're in a buying mindset and considering alternatives.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">📊</div>
          <div class="benefit-content">
            <h3>Real-Time Insights</h3>
            <p>Track impressions, click-through rates, foot traffic attribution, and audience engagement in real time. Know exactly how your investment is performing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Numbers — WHITE -->
  <section class="stats-section">
    <div class="container">
      <h2>The Numbers Don't Lie</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">80%</div>
          <div class="stat-label">of consumers are more likely to purchase from brands that serve personalized, location-relevant ads</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">2.5×</div>
          <div class="stat-label">higher click-through rate for geofenced display ads compared to standard display campaigns</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">53%</div>
          <div class="stat-label">of shoppers visited a retailer after receiving a location-based message or ad</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works — VIDEO BG -->
  <section class="animated-bg-section">
  <div class="container section-content">
      <h2>How It Works</h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>On-Boarding Meeting</h3>
            <p>We learn your business, target audience, and competitive landscape to identify the highest-value geofencing locations and strategy.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Creative Development</h3>
            <p>Our design team builds eye-catching display ads in multiple formats — static banners, rich media, and full-motion creatives optimized for every screen size.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Campaign Launch</h3>
            <p>We activate your geofences, deploy your ads across premium websites and apps, and start capturing device IDs as your audience enters target zones.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Reporting & Optimization</h3>
            <p>You receive clear, detailed reports on impressions, clicks, and audience reach. We continuously refine targeting and creative to maximize results.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach — WHITE -->
  <section class="approach-section">
    <div class="container">
      <h2>Our Approach</h2>
      <p class="approach-intro">Every display and geofencing campaign follows our proven five-step process for measurable results.</p>
      <ol class="approach-list">
        <li><strong>Discovery</strong> — We audit your market, competitors, and audience to identify the locations and demographics that matter most.</li>
        <li><strong>Strategy</strong> — We define geofence boundaries, targeting parameters, ad formats, and budget allocation for maximum reach and ROI.</li>
        <li><strong>Execution</strong> — Your ads go live across premium display networks, reaching the right people in the right places at the right time.</li>
        <li><strong>Evaluation</strong> — We analyze impressions, click-through rates, foot traffic attribution, and conversion paths to measure campaign impact.</li>
        <li><strong>Optimization</strong> — We refine geofence locations, adjust creative, and reallocate budget to the highest-performing tactics throughout the campaign.</li>
      </ol>
    </div>
  </section>

  <!-- Who It's For — VIDEO BG -->
  <section class="animated-bg-section">
  <div class="container section-content">
      <h2>Who It's For</h2>
      
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">🏪</div>
          <div class="benefit-content">
            <h3>Retail & Restaurants</h3>
            <p>Geofence shopping centers, competitor locations, and high-traffic areas to drive foot traffic and promote offers to nearby consumers in your area.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">⚖️</div>
          <div class="benefit-content">
            <h3>Professional Services</h3>
            <p>Law firms, medical practices, and financial advisors — build brand authority by targeting audiences in courthouses, business districts, and industry events.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🏠</div>
          <div class="benefit-content">
            <h3>Home Services</h3>
            <p>HVAC, plumbing, roofing, and landscaping companies — target homeowners in specific neighborhoods and subdivisions where you want to grow.</p>
          </div>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">🎓</div>
          <div class="benefit-content">
            <h3>Education & Events</h3>
            <p>Universities, trade schools, and event organizers — reach attendees at conferences, career fairs, and campus areas to boost enrollment and attendance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ — WHITE -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faq.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">{item.question}</summary>
            <p class="faq-answer">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Services That Pair Well — VIDEO BG -->
  <section class="animated-bg-section related-section">
  <div class="container section-content">
      <h2>Services That Pair Well</h2>
      <p class="related-intro">Amplify your geofencing campaigns with these complementary strategies.</p>
      <div class="related-services">
        {relatedServices.map((service) => (
          <a href={service.href} class="related-pill">{service.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — WHITE -->
  <section class="cta-section-white">
    <div class="container">
      <h2>Ready to Reach Your Audience Where They Are?</h2>
      <p>Stop wasting ad spend on broad, untargeted campaigns — let's put your brand in front of the right people in the right places across the Midlands.</p>
      <a href="/contact-us/" class="btn-red">Let's Talk!</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ==================== SHARED LAYOUT ==================== */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ==================== TRANSPARENT SECTIONS ==================== */
  .intro-section,
  .stats-section,
  .approach-section,
  .faq-section,
  .cta-section-white {
    padding: 5rem 0;
    background: transparent;
    color: #ffffff;
  }

  .intro-section h2,
  .stats-section h2,
  .approach-section h2,
  .faq-section h2,
  .cta-section-white h2 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin-bottom: 1.5rem;
    text-align: center;
    color: #ffffff;
  }

  .intro-text {
    font-size: 1.15rem;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    color: rgba(210, 232, 255, 0.9);
  }

  /* ==================== VIDEO BG SECTIONS ==================== */
  .video-bg-section {
    position: relative;
    padding: 5rem 0;
    overflow: hidden;
  }

  .section-video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 0;
  }

  .section-video-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 1;
  }

  .section-content {
    position: relative;
    z-index: 2;
  }

  .video-bg-section h2 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin-bottom: 2rem;
    text-align: center;
    color: #ffffff;
  }

  /* ==================== BENEFITS / CARDS GRID ==================== */
  .benefits-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .benefits-grid > * {
    flex: 0 1 calc(33.333% - 1rem);
    min-width: 260px;
  }

  .benefit-card {
    background: rgba(30, 30, 35, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .benefit-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .benefit-card h3 {
    color: #ffffff;
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .benefit-card p {
    color: rgba(210, 232, 255, 0.85);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ==================== STATS ==================== */
  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .stats-grid > * {
    flex: 0 1 calc(33.333% - 1rem);
    min-width: 220px;
  }

  .stat-card {
    background: rgba(30, 30, 35, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .stat-number {
    font-size: 2.8rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.95rem;
    color: rgba(210, 232, 255, 0.85);
    line-height: 1.5;
  }

  /* ==================== PROCESS STEPS ==================== */
  .process-steps {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 1 calc(25% - 1.2rem);
    min-width: 200px;
    background: rgba(30, 30, 35, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .step-number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e63946, #c1121f);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .step-content h3 {
    color: #ffffff;
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }

  .step-content p {
    color: rgba(210, 232, 255, 0.85);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ==================== APPROACH ==================== */
  .approach-intro {
    text-align: center;
    color: rgba(210, 232, 255, 0.9);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .approach-list {
    max-width: 800px;
    margin: 0 auto;
    padding-left: 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .approach-list li {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(210, 232, 255, 0.85);
  }

  .approach-list li strong {
    color: #ffffff;
  }

  /* ==================== FAQ ==================== */
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    background: rgba(30, 30, 35, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
  }

  .faq-question {
    font-weight: 600;
    font-size: 1.05rem;
    color: #ffffff;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-question::after {
    content: "+";
    font-size: 1.3rem;
    font-weight: 300;
    color: rgba(210, 232, 255, 0.6);
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-question::after {
    content: "−";
  }

  .faq-answer {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(210, 232, 255, 0.85);
  }

  /* ==================== RELATED SERVICES ==================== */
  .related-intro {
    text-align: center;
    color: rgba(210, 232, 255, 0.85);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .related-services {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .related-pill {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .related-pill:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #ffffff;
  }

  /* ==================== WHITE CTA ==================== */
  .cta-section-white {
    text-align: center;
    padding: 5rem 0;
  }

  .cta-section-white p {
    font-size: 1.15rem;
    color: rgba(210, 232, 255, 0.9);
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ==================== BUTTON ==================== */
  .btn-red {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    background: linear-gradient(135deg, #e63946, #c1121f);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 50px;
    text-decoration: none;
    border: 2px solid #b82232;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-red:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(230, 57, 70, 0.4);
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
