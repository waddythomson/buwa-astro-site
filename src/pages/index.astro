---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "BuWa Digital - Marketing & Advertising for Local Businesses";
const description = "Reach more customers where they live, work, and shop with targeted digital marketing that builds trust and drives action.";
---

<BaseLayout title={title} description={description}>
  <script is:inline>
    (function () {
      // Apply page-type classes immediately (before paint) to prevent flash.
      document.documentElement.classList.add('home-page', 'digital-home');
      document.body.classList.add('home-page', 'digital-home');
      // Lock scroll during reveal only on first visit.
      // For return visits, add home-skip-reveal so CSS hides #homeReveal before first paint.
      var isReturn = Boolean(sessionStorage.getItem('buwa-home-visited'));
      if (!isReturn) {
        document.documentElement.classList.add('home-loading');
        document.body.classList.add('home-loading');
      } else {
        // Hide overlay before paint on return visits — only ViewTransitions slide-in should run
        document.documentElement.classList.add('home-skip-reveal');
      }
    })();
  </script>

  <div class="home-reveal" id="homeReveal" aria-hidden="true">
    <div class="home-reveal-logo-wrap">
      <img src="/uploads/logos/buwa-digital-white.png" alt="" class="home-reveal-logo" />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video class="hero-video hero-video-a is-active" muted playsinline preload="auto">
        <source src="/uploads/hero/0.mp4" type="video/mp4" />
      </video>
      <video class="hero-video hero-video-b" muted playsinline preload="metadata">
        <source src="" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
      <div class="hero-stars"></div>
      <div class="hero-stars hero-stars-secondary"></div>
      <div class="hero-moon"></div>
    </div>
    <div class="hero-content">
      <h1>Why Not You?</h1>
      <p class="hero-subtitle">Whether you're a fresh startup or local legend, let's make sure they choose you.</p>
      <div class="hero-buttons">
        <a href="/contact-us/" class="cta-button cta-button-red">Let's Talk!</a>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="features animated-bg-section">
    <div class="container">
      <div class="feature-grid">
        <div class="feature-image">
          <img src="/uploads/2024/Indoor-Billboards.webp" alt="Indoor Billboards" loading="lazy" />
        </div>
        <div class="feature-content">
          <div class="feature-item">
            <h3>Tired Of Blowing The Budget On Advertising?</h3>
            <p>We understand how difficult – and expensive — it can be to get customers to pay attention.</p>
            <p>We help local business owners stop wasting money on underperforming ads by telling their story through locally targeted, full-motion video that delivers real results — without breaking the bank.</p>
          </div>
          <div class="feature-item">
            <h3>Be Seen. Be Trusted. Be Chosen!</h3>
          <p>Customers trust brands that they recognize. By using vibrant visuals and smart campaigns to tell your story, you gain valuable local exposure and <strong>turn recognition into trust</strong>— the trust that ultimately leads to being chosen.</p>
          </div>
        </div>
      </div>
      <div class="feature-cta">
        <a
          href="/buwatv/"
          class="cta-button cta-button-navy cta-button-logo"
          aria-label="Visit BuWaTV"
        >
          <i class="fa-solid fa-arrow-up-right-from-square"></i>
          <img src="/uploads/logos/buwa-tv-white.png" alt="BuWa TV" class="cta-logo" />
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats animated-bg-section">
    <div class="container">
      <div class="stat-grid">
        <div class="stat-item">
          <span class="stat-number" data-count="400">400%</span>
          <span class="stat-label">More Impactful Than Static Advertising</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="30">30%</span>
          <span class="stat-label">Increase in Average Ticket Value</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="83">83%</span>
          <span class="stat-label">Recall Among Consumers</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Growth Partners -->
  <section class="network">
    <div class="container">
      <div class="network-grid">
        <div class="network-content">
          <h2>Local Growth Partners</h2>
          <p>Our mission is to help local businesses like yours reach the right audience with coordinated search, social, and web campaigns.</p>
          <p>We build the strategy, creative, and execution so your brand stays visible and competitive.</p>
          <a href="/contact-us/" class="cta-button cta-button-red">Let's Talk!</a>
        </div>
        <div class="network-image">
          <img src="/uploads/2024/FSScreen_Grocery_YourAd2.jpg" alt="Local business marketing" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Marketing Solutions -->
  <section class="solutions animated-bg-section">
    <div class="container">
      <h2>Marketing Solutions</h2>
      <div class="solution-grid">
        <a href="/buwatv/" class="solution-card">
          <img src="/uploads/logos/buwa-tv-white.png" alt="BuWa TV" class="solution-icon solution-icon-image" loading="lazy" />
          <h3>Indoor Digital Billboards</h3>
          <p>Showcase your brand on screens in locations where customers work, shop, eat, and play.</p>
        </a>
        <a href="/google-business-profile/" class="solution-card">
          <i class="fa-brands fa-google solution-icon"></i>
          <h3>Google Business Profile</h3>
          <p>Optimize your profile to increase online visibility, improve local search rankings, and attract more customers to your business</p>
        </a>
        <a href="/pay-per-click-ppc/" class="solution-card">
          <i class="fa-solid fa-hand-point-up solution-icon"></i>
          <h3>Pay-Per-Click (PPC)</h3>
          <p>Drive immediate traffic and convert more leads with strategic, budget-friendly online advertising</p>
        </a>
        <a href="/website-design/" class="solution-card">
          <i class="fa-solid fa-object-ungroup solution-icon"></i>
          <h3>Website Design</h3>
          <p>Create a positive first impression, increase customer engagement and conversions</p>
        </a>
      </div>
      <div class="solutions-cta">
        <a href="/solutions/" class="cta-button">Browse all Services</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials" id="testimonials">
    <div class="container">
      <h2>What Our Partners Are Saying</h2>
      <p class="testimonials-subtitle">Don't just take our word for it.</p>
      <div class="testimonial-grid">
        <div class="testimonial-card">
          <div class="stars">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>
          <p class="testimonial-text">"Incredible service and team. Buck and Waddy have nailed it when it comes to business-to-business advertising that is visually appealing, fresh and fun. This has been a great way to advertise events, news and company info. It's easy to tell they love and support the small business community."</p>
          <div class="testimonial-author">
            <span class="author-name">Christina Nelson</span>
            <span class="author-company">The Greater CWC Chamber of Commerce</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="stars">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>
          <p class="testimonial-text">"Buwa Digital is the real deal when it comes to helping local businesses grow in today's digital world. Their indoor digital billboards are a game-changer for visibility. What I appreciate most is their passion for empowering small businesses here in Columbia. It feels less like hiring a vendor and more like gaining a partner who's invested in your success."</p>
          <div class="testimonial-author">
            <span class="author-name">David Medley</span>
            <span class="author-company">Better Homes and Gardens Real Estate Medley</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="stars">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>
          <p class="testimonial-text">"Buwa Digital has been a tremendous help in improving my business's online presence. They made the process of setting up and optimizing my Google Business page simple and effective. Their team was responsive, professional, and delivered exactly what they promised. I've already noticed a difference in how clients are finding us online."</p>
          <div class="testimonial-author">
            <span class="author-name">Zach Coggins</span>
            <span class="author-company">Milestone Wealth Advisors</span>
          </div>
        </div>
      </div>
      <div class="google-attribution">
        <i class="fa-brands fa-google"></i> Reviews from Google
      </div>
    </div>
  </section>

  <!-- Write Us a Review -->
  <section class="review animated-bg-section">
    <div class="container">
      <h2>Write Us a Review</h2>
      <p>We'd love to hear about your experience working with us!</p>
      <a href="https://g.page/r/CaCY12nNkQppEBM/review" class="cta-button cta-button-red" target="_blank" rel="noopener">Leave One Now</a>
    </div>
  </section>
</BaseLayout>

<script>
  // astro:page-load fires on every ViewTransitions navigation (including initial load).
  // Without this, the script only runs once and the video never starts on back-nav.
  document.addEventListener('astro:page-load', () => {
    if (!document.body.classList.contains('home-page')) return;
    // Stats animation
    const statNumbers = document.querySelectorAll('.stat-number[data-count]');
    const animateCount = (el) => {
      const target = Number(el.dataset.count || '0');
      const duration = 1200;
      const start = performance.now();
  
      const step = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const value = Math.round(progress * target);
        el.textContent = `${value}%`;
        if (progress < 1) requestAnimationFrame(step);
      };
  
      requestAnimationFrame(step);
    };
  
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          if (el.dataset.animated) return;
          el.dataset.animated = 'true';
          animateCount(el);
          obs.unobserve(el);
        });
      },
      { threshold: 0.4 }
    );
  
    statNumbers.forEach((el) => observer.observe(el));
  
    // Intro video splash (6 seconds)
    const introDurationMs = 4500;
    const introStartTimeoutMs = 900;
    const enableIntroSplash = false;
    const introVideo = document.getElementById('introVideo');
    const introVideoEl = document.getElementById('introVideoEl');
    const homeReveal = document.getElementById('homeReveal');
    const heroVideoEls = Array.from(document.querySelectorAll('.hero-video'));
    let heroPlaylist = ['/uploads/hero/0.mp4'];
    let heroPlaylistIndex = 0;
    let activeHeroVideoIndex = 0;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
    const prefersSmallVideo = window.matchMedia('(max-width: 1024px)').matches
      || Boolean(connection?.saveData)
      || ['slow-2g', '2g', '3g'].includes(connection?.effectiveType || '');
    // Track whether this is a same-session return (back button, etc.)
    const isReturnVisit = Boolean(sessionStorage.getItem('buwa-home-visited'));
    sessionStorage.setItem('buwa-home-visited', 'true');
  
    const cameFromSameSite = (() => {
      if (!document.referrer) return false;
      try {
        return new URL(document.referrer).origin === window.location.origin;
      } catch {
        return false;
      }
    })();
    const navEntry = performance.getEntriesByType('navigation')[0];
    const isReloadNavigation = navEntry?.type === 'reload';
    let playbackTimer;
    let maxWaitTimer;
    let hasPlayed = false;
    let pendingSwap = false;
    let introDismissed = false;
    let heroStarted = false;
  
    const waitForHeroFirstFrame = (timeoutMs = 1800) => {
      const activeVideo = heroVideoEls[activeHeroVideoIndex];
      if (!(activeVideo instanceof HTMLVideoElement)) return Promise.resolve();
      if (activeVideo.readyState >= 2) {
        return new Promise((resolve) => {
          requestAnimationFrame(() => requestAnimationFrame(resolve));
        });
      }
  
      return new Promise((resolve) => {
        const done = () => {
          clearTimeout(timer);
          activeVideo.removeEventListener('loadeddata', done);
          activeVideo.removeEventListener('playing', done);
          requestAnimationFrame(() => requestAnimationFrame(resolve));
        };
        const timer = window.setTimeout(done, timeoutMs);
        activeVideo.addEventListener('loadeddata', done, { once: true });
        activeVideo.addEventListener('playing', done, { once: true });
      });
    };
  
    const ensureHeroVideoStarted = () => {
      if (heroStarted) return Promise.resolve();
      heroStarted = true;
      return startHeroVideo();
    };
  
  
    const clearTimers = () => {
      if (playbackTimer) {
        clearTimeout(playbackTimer);
        playbackTimer = undefined;
      }
      if (maxWaitTimer) {
        clearTimeout(maxWaitTimer);
        maxWaitTimer = undefined;
      }
    };
  
    const setVideoSource = (videoEl, src) => {
      if (!(videoEl instanceof HTMLVideoElement)) return;
      const sourceEl = videoEl.querySelector('source');
      const typeFromSrc = (value) => (value.endsWith('.webm') ? 'video/webm' : 'video/mp4');
      const withLowresVariant = (value) =>
        value.replace(/(\.[a-z0-9]+)(\?.*)?$/i, '-lowres$1$2');
      const with720Variant = (value) =>
        value.replace(/(\.[a-z0-9]+)(\?.*)?$/i, '-720$1$2');
      const candidateSources = prefersSmallVideo
        ? [withLowresVariant(src), with720Variant(src), src]
        : [src];
      let sourceIndex = 0;
  
      const applySource = (sourceUrl, type) => {
        if (sourceEl) {
          sourceEl.src = sourceUrl;
          sourceEl.type = type;
        } else {
          videoEl.src = sourceUrl;
        }
        videoEl.load();
      };
  
      if (candidateSources.length > 1) {
        videoEl.onerror = () => {
          sourceIndex += 1;
          const nextSrc = candidateSources[sourceIndex];
          if (!nextSrc) {
            videoEl.onerror = null;
            return;
          }
          if (sourceIndex >= candidateSources.length - 1) {
            videoEl.onerror = null;
          }
          applySource(nextSrc, typeFromSrc(nextSrc));
        };
      } else {
        videoEl.onerror = null;
      }
  
      applySource(candidateSources[0], typeFromSrc(candidateSources[0]));
    };
  
    const loadHeroPlaylist = async () => {
      try {
        const response = await fetch('/uploads/hero/playlist.json', { cache: 'no-store' });
        if (!response.ok) return;
        const data = await response.json();
        if (Array.isArray(data.videos) && data.videos.length > 0) {
          heroPlaylist = data.videos;
        }
      } catch {
        // Keep default list if playlist fails to load
      }
    };
  
    const startHeroVideo = async () => {
      if (prefersReducedMotion) return;
      if (heroVideoEls.length < 2) return;
      const crossfadeLeadSeconds = 0.35;
  
      await loadHeroPlaylist();
      if (heroPlaylist.length === 0) return;
  
      // Single-clip playlists should use native looping to avoid
      // any handoff flash from swapping between layered video elements.
      if (heroPlaylist.length === 1) {
        const primaryVideo = heroVideoEls[0];
        const secondaryVideo = heroVideoEls[1];
        if (!(primaryVideo instanceof HTMLVideoElement)) return;
  
        primaryVideo.classList.add('is-active');
        primaryVideo.loop = true;
        primaryVideo.muted = true;
        primaryVideo.playsInline = true;
        setVideoSource(primaryVideo, heroPlaylist[0]);
        primaryVideo.play().catch(() => {});
  
        if (secondaryVideo instanceof HTMLVideoElement) {
          secondaryVideo.classList.remove('is-active');
          secondaryVideo.pause();
        }
        return;
      }
  
      const getActiveVideo = () => heroVideoEls[activeHeroVideoIndex];
      const getBufferVideo = () => heroVideoEls[(activeHeroVideoIndex + 1) % heroVideoEls.length];
  
      const preloadNextClip = () => {
        const bufferVideo = getBufferVideo();
        const nextIndex = (heroPlaylistIndex + 1) % heroPlaylist.length;
        setVideoSource(bufferVideo, heroPlaylist[nextIndex]);
      };
  
      const swapToNextClip = () => {
        if (pendingSwap) return;
        pendingSwap = true;
  
        const currentVideo = getActiveVideo();
        const bufferVideo = getBufferVideo();
        const nextIndex = (heroPlaylistIndex + 1) % heroPlaylist.length;
  
        bufferVideo.currentTime = 0;
        bufferVideo.play()
          .then(() => {
            bufferVideo.classList.add('is-active');
            currentVideo.classList.remove('is-active');
            currentVideo.pause();
            heroPlaylistIndex = nextIndex;
            activeHeroVideoIndex = (activeHeroVideoIndex + 1) % heroVideoEls.length;
            preloadNextClip();
          })
          .catch(() => {
            // If buffered play fails, keep current frame and retry on next loop.
          })
          .finally(() => {
            pendingSwap = false;
          });
      };
  
      heroVideoEls.forEach((video) => {
        video.muted = true;
        video.playsInline = true;
        video.loop = false;
        video.addEventListener('timeupdate', () => {
          if (video !== getActiveVideo() || pendingSwap) return;
          if (!Number.isFinite(video.duration) || video.duration <= 0) return;
          const remaining = video.duration - video.currentTime;
          if (remaining <= crossfadeLeadSeconds) {
            swapToNextClip();
          }
        });
        video.addEventListener('ended', () => {
          if (video !== getActiveVideo()) return;
          swapToNextClip();
        });
      });
  
      const activeVideo = getActiveVideo();
      setVideoSource(activeVideo, heroPlaylist[heroPlaylistIndex]);
      activeVideo.play().catch(() => {});
      preloadNextClip();
    };
  
    const hideIntro = async () => {
      if (introDismissed) return;
      introDismissed = true;
      if (!enableIntroSplash) {
        document.body.classList.remove('intro-active');
        introVideo?.remove();
        await ensureHeroVideoStarted();
        await waitForHeroFirstFrame(2200);
        const revealHoldMs = 1750;
        const revealExitMs = 720;
        requestAnimationFrame(() => {
          homeReveal?.classList.add('is-ready');
        });
        setTimeout(() => {
          homeReveal?.classList.add('is-opening');
        }, revealHoldMs);
        setTimeout(() => {
          document.documentElement.classList.remove('home-loading');
          document.body.classList.remove('home-loading');
          homeReveal?.remove();
        }, revealHoldMs + revealExitMs + 40);
        return;
      }
      if (!introVideo) {
        await ensureHeroVideoStarted();
        await waitForHeroFirstFrame();
        return;
      }
      const introWasVisible = introVideo.classList.contains('active');
      if (!introWasVisible) {
        // For skip-intro navigations, keep a solid cover until hero first frame.
        introVideo.classList.add('active', 'boot-only');
      }
      document.body.classList.remove('intro-active');
      clearTimers();
      if (introVideoEl) {
        introVideoEl.pause();
        introVideoEl.currentTime = 0;
      }
      await ensureHeroVideoStarted();
      await waitForHeroFirstFrame();
      introVideo.classList.add('done');
      setTimeout(() => introVideo.remove(), 500);
    };
  
    const showIntro = () => {
      if (!introVideo) return;
      introVideo.classList.remove('boot-only');
      document.body.classList.add('intro-active');
      introVideo.classList.add('active');
      if (introVideoEl instanceof HTMLVideoElement) {
        introVideoEl.muted = true;
        introVideoEl.playsInline = true;
        introVideoEl.addEventListener(
          'playing',
          () => {
            hasPlayed = true;
            playbackTimer = setTimeout(hideIntro, introDurationMs);
          },
          { once: true }
        );
        introVideoEl.addEventListener('error', hideIntro, { once: true });
        maxWaitTimer = setTimeout(() => {
          if (!hasPlayed) hideIntro();
        }, introStartTimeoutMs);
        introVideoEl.play().catch(() => {
          hideIntro();
        });
      } else {
        hideIntro();
      }
    };
  
    if (isReturnVisit) {
      // Return visit — skip the logo-reveal panel.
      // Astro ViewTransitions already plays the slide-in page animation.
      document.documentElement.classList.remove('home-loading');
      document.body.classList.remove('home-loading');
      homeReveal?.remove();
      ensureHeroVideoStarted();
    } else if (
      enableIntroSplash
      && !prefersReducedMotion
      && (!cameFromSameSite || isReloadNavigation)
      && introVideoEl?.querySelector('source')?.getAttribute('src')
    ) {
      showIntro();
    } else {
      hideIntro();
    }
  
  });
</script>

<style>
  :global(html.digital-home),
  :global(body.digital-home) {
    background: #1a1a2e;
  }

  :global(html.home-loading),
  :global(body.home-loading) {
    overflow: hidden;
  }

  :global(body.intro-active) {
    overflow: hidden;
  }

  .intro-video {
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .intro-video.active {
    opacity: 1;
    pointer-events: auto;
  }

  .intro-video.done {
    opacity: 0;
    pointer-events: none;
  }

  .intro-video.boot-only {
    transition: none;
    background: #000;
  }

  .intro-video.boot-only .intro-video-el {
    visibility: hidden;
  }

  .intro-video-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    visibility: hidden;
    background-color: #000;
    background-image: url('/uploads/logos/buwa-digital-logo-1.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: clamp(180px, 42vw, 420px) auto;
  }

  .intro-video.active .intro-video-el {
    visibility: visible;
  }

  :global(html.home-skip-reveal) #homeReveal {
    display: none;
  }

  .home-reveal {
    position: fixed;
    inset: 0;
    z-index: 10010;
    background: #e6e4de;
    display: grid;
    place-items: center;
    transform: translateY(0);
    opacity: 1;
    transition: transform 0.72s cubic-bezier(0.2, 0.65, 0.2, 1), opacity 0.72s ease;
    will-change: transform, opacity;
    pointer-events: none;
    perspective: 1200px;
  }

  .home-reveal-logo-wrap {
    width: clamp(190px, 24vw, 320px);
    opacity: 0;
    transform: translateX(-12px) scale(0.16);
    transition: transform 0.9s cubic-bezier(0.18, 0.8, 0.22, 1), opacity 0.52s ease;
    will-change: transform, opacity;
  }

  .home-reveal.is-ready .home-reveal-logo-wrap {
    opacity: 1;
    transform: translateX(0) scale(1);
  }

  .home-reveal-logo {
    width: 100%;
    height: auto;
    display: block;
    filter: invert(1) brightness(0.08);
  }

  .home-reveal.is-opening {
    transform: translateY(-108%);
    opacity: 0;
  }

  .home-reveal.is-opening .home-reveal-logo-wrap {
    transform: translate(-34vw, -30vh) scale(0.26);
    opacity: 0.18;
    transition-duration: 0.7s, 0.56s;
    transition-timing-function: cubic-bezier(0.3, 0.74, 0.22, 1), ease;
  }

  .hero {
    --hero-header-overlap: var(--site-header-height, 94px);
    --hero-overdraw: 50px;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: white;
    margin-top: calc(var(--hero-header-overlap) * -1 - var(--hero-overdraw));
    padding: calc(1.2rem + var(--hero-header-overlap) + var(--hero-overdraw)) 2rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-media {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 0;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
