---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const faq = [
  {
    question: "Why should I claim my listing?",
    answer: "Claiming your profile gives you control over the information Google displays and helps prevent inaccuracies that can cost you customers.",
  },
  {
    question: "What if I do not have access to the previous owner's account?",
    answer: "We can help you regain access by working through Google's verification steps and submitting the documentation needed to prove ownership.",
  },
  {
    question: "How important is it to have a Google Business Profile?",
    answer: "A claimed and optimized profile improves visibility in Search and Maps, builds trust, and drives more local actions like calls, directions, and website visits.",
  },
];

const relatedServices = [
  { label: "Website Design", href: "/website-design/" },
  { label: "Pay-Per-Click (PPC)", href: "/pay-per-click-ppc/" },
  { label: "Display Advertising | Geofencing", href: "/geofencing/" },
  { label: "Social Media Ads", href: "/social-media-ads/" },
];

const partnerQuote = {
  quote: "Buwa Digital has been a tremendous help in improving my business's online presence. They made the process of setting up and optimizing my Google Business page simple and effective.",
  name: "Zach Coggins",
  company: "Milestone Wealth Advisors",
};
---

<BaseLayout 
  title="Google Business Profile Management | BuWa Digital"
  description="Improve your Google Business Profile performance so you appear in more relevant local searches and attract more customers."
  faq={faq}
  hasTopHero={true}
>
  <!-- Hero Section -->
  <PageHero
    title="Google Business Profile"
    subtitle="Boost the performance of your Google Business Profile so you appear on more relevant search result pages."
  >
    <a href="#open-scan-popup" class="btn-red">
      <i class="fa-solid fa-magnifying-glass"></i> Ask For A Free Scan
    </a>
  </PageHero>
