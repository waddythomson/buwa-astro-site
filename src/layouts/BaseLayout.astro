---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: string;
  noindex?: boolean;
  hasTopHero?: boolean;
  twitterSite?: string;
  twitterCreator?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
  breadcrumbs?: Array<{ name: string; url: string }>;
  faq?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description = "BuWa Digital - Indoor digital billboard advertising that helps local businesses reach their audience.",
  canonicalUrl,
  ogImage = "/uploads/2024/buwa-logo.png",
  ogImageAlt,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogType = "website",
  noindex = false,
  twitterSite,
  twitterCreator,
  publishedTime,
  modifiedTime,
  author,
  tags = [],
  breadcrumbs,
  faq = [],
  hasTopHero = false,
} = Astro.props;

const siteUrl = import.meta.env.SITE || 'https://buwadigital.com';
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;
const ogImageAltText = ogImageAlt || title;
const absoluteLogo = new URL('/uploads/2024/buwa-logo.png', siteUrl).href;
const sameAs: string[] = [];
const resolvedTwitterSite = twitterSite || import.meta.env.PUBLIC_TWITTER_SITE;
const resolvedTwitterCreator = twitterCreator || import.meta.env.PUBLIC_TWITTER_CREATOR;

const formatBreadcrumbLabel = (slug: string) => {
  const acronyms = new Set(['PPC', 'SEO', 'OTT', 'CTV', 'TV']);
  return slug
    .replace(/[-_]/g, ' ')
    .split(' ')
    .filter(Boolean)
    .map((word) => {
      const upper = word.toUpperCase();
      if (acronyms.has(upper)) return upper;
      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join(' ');
};

const buildBreadcrumbs = () => {
  const segments = Astro.url.pathname.split('/').filter(Boolean);
  const skipSegments = new Set(['blog']);
  const items = [{ name: 'Home', url: `${siteUrl}/` }];
  let path = '';

  segments.forEach((segment) => {
    if (skipSegments.has(segment)) {
      path += `/${segment}`;
      return;
    }
    path += `/${segment}`;
    items.push({
      name: formatBreadcrumbLabel(segment),
      url: `${siteUrl}${path}/`,
    });
  });

  return items;
};

const breadcrumbItems = breadcrumbs?.length ? breadcrumbs : buildBreadcrumbs();
const breadcrumbJsonLd = breadcrumbItems.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "name": item.name,
        "item": item.url,
      })),
    }
  : undefined;

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "BuWa Digital",
  "url": siteUrl,
  "logo": absoluteLogo,
  "sameAs": sameAs,
};

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "BuWa Digital",
  "description": "Local isn't just our market—it's our mission. We help local businesses reach more neighbors with affordable, high-impact digital advertising including indoor digital billboards, geofencing, social media, and streaming TV ads.",
  "url": siteUrl,
  "logo": absoluteLogo,
  "image": absoluteLogo,
  "telephone": "+1-803-200-1614",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1926 Augusta Rd.",
    "addressLocality": "West Columbia",
    "addressRegion": "SC",
    "postalCode": "29169",
    "addressCountry": "US",
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "17:00",
    },
  ],
  "sameAs": sameAs,
};

const articleJsonLd = ogType === 'article'
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "image": [fullOgImage],
      "author": author
        ? { "@type": "Person", "name": author }
        : { "@type": "Organization", "name": "BuWa Digital" },
      "publisher": {
        "@type": "Organization",
        "name": "BuWa Digital",
        "logo": {
          "@type": "ImageObject",
          "url": absoluteLogo,
        },
      },
      "datePublished": publishedTime?.toISOString(),
      "dateModified": (modifiedTime || publishedTime)?.toISOString(),
      "mainEntityOfPage": currentUrl,
      "keywords": tags.length ? tags.join(', ') : undefined,
    }
  : undefined;

const faqJsonLd = faq.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        },
      })),
    }
  : undefined;

const normalizedPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isDigitalHome = normalizedPath === '/' || normalizedPath === '/index.html';
const rootClassName = isDigitalHome ? 'home-page digital-home' : (hasTopHero ? 'secondary-top-hero' : undefined);
---

<!DOCTYPE html>
<html lang="en" class={rootClassName}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Canonical URL -->
  <link rel="canonical" href={currentUrl} />
  <link rel="alternate" hreflang="en-US" href={currentUrl} />
  <link rel="alternate" hreflang="x-default" href={currentUrl} />

  <!-- Robots -->
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:alt" content={ogImageAltText} />
  <meta property="og:image:width" content={String(ogImageWidth)} />
  <meta property="og:image:height" content={String(ogImageHeight)} />
  <meta property="og:site_name" content="BuWa Digital" />

  {ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime.toISOString()} />
  )}
  {ogType === 'article' && (modifiedTime || publishedTime) && (
    <meta property="article:modified_time" content={(modifiedTime || publishedTime).toISOString()} />
  )}
  {ogType === 'article' && author && (
    <meta property="article:author" content={author} />
  )}
  {ogType === 'article' && tags.length > 0 && tags.map((tag) => (
    <meta property="article:tag" content={tag} />
  ))}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />
  <meta name="twitter:image:alt" content={ogImageAltText} />
  {resolvedTwitterSite && <meta name="twitter:site" content={resolvedTwitterSite} />}
  {resolvedTwitterCreator && <meta name="twitter:creator" content={resolvedTwitterCreator} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@300;400;500;600;700;800&family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet" />

  <!-- LocalBusiness Structured Data -->
  <script type="application/ld+json">
  {JSON.stringify(localBusinessJsonLd)}
  </script>
  <script type="application/ld+json">
  {JSON.stringify(organizationJsonLd)}
  </script>
  {breadcrumbJsonLd && (
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbJsonLd)}
    </script>
  )}
  {articleJsonLd && (
    <script type="application/ld+json">
      {JSON.stringify(articleJsonLd)}
    </script>
  )}
  {faqJsonLd && (
    <script type="application/ld+json">
      {JSON.stringify(faqJsonLd)}
    </script>
  )}
  <!-- Page transitions -->
  <ViewTransitions />

  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-3CI9d2ziqSEmZcelpcAS8.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>
</head>
<body class={rootClassName}>

  {/* Persistent full-viewport background video — only on non-homepage pages.
      transition:persist keeps this element alive across SPA navigations so
      the video loads ONCE per session and never restarts. */}
  {!isDigitalHome && (
    <div class="page-bg-video" transition:persist="page-bg-video" aria-hidden="true">
      <video autoplay muted loop playsinline preload="none">
        <source src="/uploads/new/hero/abstract/abstract-blue-1.webm" type="video/webm" />
        <source src="/uploads/new/hero/abstract/abstract-blue-1.mp4" type="video/mp4" />
      </video>
    </div>
  )}

  <div class="page-content-layer">
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </div>

  <!-- Global Contact Popup -->
  <div class="contact-modal" id="contactModal">
    <div class="contact-modal-content">
      <button type="button" class="contact-modal-close" id="closeContactPopup">&times;</button>
      <div class="contact-modal-inner">
        <div class="contact-modal-header">
          <h2>Talk to us!</h2>
          <p>Tell us about your business and we'll reach out to discuss how we can help.</p>
        </div>
        <form id="contact-popup-form" class="contact-popup-form">
          <input type="hidden" name="form_type" value="contact_popup" />
          <input type="text" name="_honeypot" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="form-group">
            <input type="text" name="name" placeholder="Your Name *" required />
          </div>
          <div class="form-group">
            <input type="email" name="email" placeholder="Email Address *" required />
          </div>
          <div class="form-group">
            <input type="tel" name="phone" placeholder="Phone Number *" required />
          </div>
          <div class="form-group form-group-checkbox sms-preference-group is-hidden">
            <input type="hidden" name="sms_consent" value="false" />
            <p class="sms-preference-title">Texting preference</p>
            <label class="checkbox-label">
              <input type="checkbox" name="sms_opt_in" />
              <span>I agree to receive text messages from BuWa Digital regarding my inquiry. Reply STOP to opt out.</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="sms_opt_out" />
              <span>I am opting out of text messages and would appreciate a phone call instead.</span>
            </label>
          </div>
          <div class="form-group">
            <textarea name="message" placeholder="How can we help? (optional)" rows="3"></textarea>
          </div>
          <button type="submit" class="contact-popup-submit">
            Send Message
          </button>
          <p class="contact-popup-disclaimer">By submitting this form, you agree to our <a href="/terms/">Terms &amp; Conditions</a> and <a href="/privacy-policy/">Privacy Policy</a>. SMS messages are only sent if you opt in above.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- Lead Capture Popup (only on Google Business Profile page) -->
  <div id="gbp-popup" class="popup-overlay" style="display: none;">
    <div class="popup-content">
      <button class="popup-close" aria-label="Close popup">&times;</button>
      <div class="popup-grid">
        <div class="popup-form-side">
          <h2>Elevate Your Online Reputation</h2>
          <p class="popup-subtitle">Ask for a free scan of your business directory listings</p>
          <form id="popup-form" class="popup-form">
            <input type="hidden" name="form_type" value="scan_request" />
            <input type="text" name="_honeypot" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="text" name="name" placeholder="Your Name" required />
            <input type="email" name="email" placeholder="Email Address" required />
            <input type="tel" name="phone" placeholder="Phone Number" />
            <div class="form-group form-group-checkbox sms-preference-group is-hidden">
              <input type="hidden" name="sms_consent" value="false" />
              <p class="sms-preference-title">Texting preference</p>
              <label class="checkbox-label">
                <input type="checkbox" name="sms_opt_in" />
                <span>I agree to receive text messages from BuWa Digital regarding my inquiry. Reply STOP to opt out.</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="sms_opt_out" />
                <span>I am opting out of text messages and would appreciate a phone call instead.</span>
              </label>
            </div>
            <input type="text" name="business" placeholder="Business Name" />
            <button type="submit" class="popup-submit">Get Started</button>
          </form>
          <p class="popup-disclaimer">By submitting this form, you agree to our <a href="/terms/">Terms &amp; Conditions</a> and <a href="/privacy-policy/">Privacy Policy</a>. SMS messages are only sent if you opt in above.</p>
        </div>
        <div class="popup-image-side">
          <img src="/uploads/2024/04/business-map.jpg" alt="Business Directory Scan" />
          <p class="popup-note">Scan will be sent once completed</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const initSmsPreferenceGroup = (form) => {
      if (!form) return;
      const phoneInput = form.querySelector('[name="phone"]');
      const group = form.querySelector('.sms-preference-group');
      const optIn = form.querySelector('[name="sms_opt_in"]');
      const optOut = form.querySelector('[name="sms_opt_out"]');
      const consent = form.querySelector('[name="sms_consent"]');
      if (!phoneInput || !group || !optIn || !optOut || !consent) return;

      const sync = () => {
        const hasPhone = Boolean(phoneInput.value.trim());
        group.classList.toggle('is-hidden', !hasPhone);
        if (!hasPhone) {
          optIn.checked = false;
          optOut.checked = false;
        }
        consent.value = optIn.checked ? 'true' : 'false';
      };

      optIn.addEventListener('change', () => {
        if (optIn.checked) optOut.checked = false;
        consent.value = optIn.checked ? 'true' : 'false';
      });

      optOut.addEventListener('change', () => {
        if (optOut.checked) optIn.checked = false;
        consent.value = optIn.checked ? 'true' : 'false';
      });

      phoneInput.addEventListener('input', sync);
      sync();
    };

    // ── Global Contact Modal — ViewTransitions-compatible ──────────────
    document.addEventListener('astro:page-load', () => {
      const controller = new AbortController();
      const { signal } = controller;
      document.addEventListener('astro:before-swap', () => controller.abort(), { once: true });

      const contactModal = document.getElementById('contactModal');
      const closeBtn = document.getElementById('closeContactPopup');
      const contactForm = document.getElementById('contact-popup-form');

      if (!contactModal || !contactForm) return;

      initSmsPreferenceGroup(contactForm);

      const openContactPopup = () => {
        contactModal.classList.add('active');
        requestAnimationFrame(() => contactModal.classList.add('ready'));
        document.body.style.overflow = 'hidden';
      };

      const closeContactPopup = () => {
        contactModal.classList.remove('ready');
        setTimeout(() => {
          contactModal.classList.remove('active');
          document.body.style.overflow = '';
        }, 200);
      };

      document.addEventListener('click', (e) => {
        const target = e.target.closest(
          'a[href="/contact-us/"], a[href="/contact-us"], button[data-contact-popup], .get-in-touch-popup'
        );
        if (target) {
          e.preventDefault();
          e.stopImmediatePropagation();
          openContactPopup();
        }
      }, { signal, capture: true });

      closeBtn?.addEventListener('click', closeContactPopup, { signal });

      contactModal.addEventListener('click', (e) => {
        if (e.target === contactModal) closeContactPopup();
      }, { signal });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && contactModal.classList.contains('active')) {
          closeContactPopup();
        }
      }, { signal });

      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        if (contactForm.querySelector('[name="_honeypot"]')?.value) {
          closeContactPopup();
          return;
        }

        const submitBtn = contactForm.querySelector('.contact-popup-submit');
        const originalHTML = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = 'Sending...';

        try {
          const formData = new FormData(contactForm);
          await fetch('/api/contact/', { method: 'POST', body: formData });
          window.location.href = '/thank-you/';
        } catch {
          window.location.href = '/thank-you/';
        }
      }, { signal });
    });
  </script>

  <script>
    // GBP scan popup — ViewTransitions compatible
    let gbpPopupController;

    document.addEventListener('astro:page-load', () => {
      gbpPopupController?.abort();

      if (!window.location.pathname.includes('google-business-profile')) return;

      gbpPopupController = new AbortController();
      const signal = gbpPopupController.signal;

      const popup = document.getElementById('gbp-popup');
      if (!popup) return;

      if (window.location.search.includes('scan-requested=true')) {
        const formSide = document.querySelector('.popup-form-side');
        if (formSide) {
          formSide.innerHTML = `
            <div style="text-align: center; padding: 2rem 0;">
              <div style="width: 60px; height: 60px; background: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: white; margin: 0 auto 1rem;">✓</div>
              <h2 style="color: white; margin-bottom: 0.5rem;">Thank You!</h2>
              <p style="color: rgba(255,255,255,0.9);">We'll send your free scan once completed.</p>
            </div>
          `;
        }
        popup.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        sessionStorage.setItem('gbp-popup-seen', 'true');
        window.history.replaceState({}, document.title, window.location.pathname);
      }

      const openPopup = () => {
        if (popup) {
          popup.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
      };

      const closePopup = () => {
        if (popup) {
          popup.style.display = 'none';
          document.body.style.overflow = '';
          sessionStorage.setItem('gbp-popup-seen', 'true');
        }
      };

      if (!window.location.search.includes('scan-requested=true')) {
        const autoTimer = setTimeout(() => {
          const hasSeenPopup = sessionStorage.getItem('gbp-popup-seen');
          if (!hasSeenPopup) {
            openPopup();
          }
        }, 1500);
        signal.addEventListener('abort', () => clearTimeout(autoTimer));
      }

      document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href="#open-scan-popup"]');
        if (link) {
          e.preventDefault();
          openPopup();
        }
      }, { signal });

      const closeBtn = popup.querySelector('.popup-close');
      closeBtn?.addEventListener('click', closePopup, { signal });
      popup.addEventListener('click', (e) => {
        if (e.target === popup) closePopup();
      }, { signal });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closePopup();
      }, { signal });

      const popupForm = document.getElementById('popup-form');
      if (popupForm) {
        initSmsPreferenceGroup(popupForm);
        popupForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          if (popupForm.querySelector('[name="_honeypot"]').value) {
            window.location.href = '/thank-you/';
            return;
          }

          const submitBtn = popupForm.querySelector('.popup-submit');
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';

          try {
            const formData = new FormData(popupForm);
            await fetch('/api/contact/', {
              method: 'POST',
              body: formData
            });
            window.location.href = '/thank-you/';
          } catch (error) {
            window.location.href = '/thank-you/';
          }
        }, { signal });
      }
    });

    document.addEventListener('astro:before-swap', () => {
      gbpPopupController?.abort();
      const popup = document.getElementById('gbp-popup');
      if (popup) {
        popup.style.display = 'none';
        document.body.style.overflow = '';
      }
    });
  </script>

  <script>
    // ── Mobile video prevention ─────────────────────────────────────────
    document.addEventListener('astro:page-load', () => {
      if (window.innerWidth <= 768) {
        document.querySelectorAll('.section-video').forEach(video => {
          video.querySelectorAll('source').forEach(s => s.remove());
          video.removeAttribute('src');
          video.load();
        });
      }
    });
  </script>

  <script>
    // Keep html's page-type classes in sync with ViewTransitions
    document.addEventListener('astro:before-swap', () => {
      document.documentElement.classList.remove(
        'home-page', 'digital-home', 'secondary-top-hero',
        'home-loading'
      );
    });

    document.addEventListener('astro:after-swap', () => {
      const b = document.body.classList;
      if (b.contains('home-page')) {
        document.documentElement.classList.add('home-page', 'digital-home');
      }
      if (b.contains('secondary-top-hero')) {
        document.documentElement.classList.add('secondary-top-hero');
      }
    });
  </script>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: 'Montserrat', system-ui, sans-serif;
    scroll-behavior: smooth;
    overscroll-behavior-y: none;
  }

  body {
    line-height: 1.6;
    color: #333;
    background: #fff;
    overscroll-behavior-y: none;
  }

  /* ─── Page-transition animations (Astro View Transitions) ─── */
  @keyframes buwa-page-enter {
    from {
      clip-path: inset(0 7vw 0 7vw round 20px 20px 0 0);
      transform: translateY(64px);
      opacity: 0;
    }
    to {
      clip-path: inset(0 0 0 0 round 0px);
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes buwa-page-exit {
    from { opacity: 1; transform: scale(1); }
    to   { opacity: 0; transform: scale(0.97); }
  }

  ::view-transition-old(root) {
    animation: 240ms ease buwa-page-exit both;
  }

  ::view-transition-new(root) {
    animation: 560ms cubic-bezier(0.22, 0.75, 0.25, 1) buwa-page-enter both;
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none !important;
    }
  }

  html.secondary-top-hero,
  body.secondary-top-hero {
    background: transparent;
  }

  /* Mobile: video is hidden, so give html a dark navy fallback */
  @media (max-width: 768px) {
    html.secondary-top-hero {
      background: #081a43;
    }
  }

  body.secondary-top-hero main > section.hero:first-child {
    padding-top: calc(3rem + var(--site-header-height, 94px));
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Inter', system-ui, sans-serif;
  }

  img {
    max-width: 100%;
    height: auto;
