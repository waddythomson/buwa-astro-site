---
// BaseLayout.astro - Shared layout for BuWa TV pages
// Provides common head elements, footer, and slots for page content
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  ogType?: string;
}

const { title, description, canonical, image, imageAlt, noindex, ogType } = Astro.props;
const baseUrl = Astro.site ?? Astro.url;
const buwaTvUrl = new URL('/buwatv/', baseUrl).toString();
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, baseUrl).toString();
const defaultImage = '/uploads/logos/buwa-tv-dark.png';
const imageUrl = new URL(image ?? defaultImage, baseUrl).toString();
const imageAltText = imageAlt ?? 'BuWa TV indoor digital billboards';
const globalNoindex = import.meta.env.PUBLIC_BUWATV_NOINDEX === 'true';
const shouldNoindex = noindex || globalNoindex;
const robotsContent = shouldNoindex ? 'noindex, nofollow' : 'index, follow';
const ogTypeValue = ogType ?? 'website';
const currentYear = new Date().getFullYear();
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'BuWa TV',
      url: buwaTvUrl,
      logo: new URL('/uploads/logos/buwa-tv-dark.png', baseUrl).toString(),
      sameAs: [
        'https://www.youtube.com/@BuWadigital',
        'https://www.facebook.com/BuWaDigital',
        'https://www.instagram.com/buwadigital'
      ]
    },
    {
      '@type': 'WebSite',
      name: 'BuWa TV',
      url: buwaTvUrl
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content={robotsContent}>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="alternate" hreflang="en-US" href={canonicalUrl}>
  <link rel="alternate" hreflang="x-default" href={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogTypeValue}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:image" content={imageUrl}>
  <meta property="og:image:alt" content={imageAltText}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/png">
  <meta property="og:site_name" content="BuWa TV">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={imageUrl}>
  <meta name="twitter:image:alt" content={imageAltText}>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600&family=Outfit:wght@600;700&display=swap" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  
  <!-- Plausible Analytics -->
  <script async src="https://plausible.io/js/pa-G2ckSejgBZ8fG_9U33pzh.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>

  <!-- Structured data -->
  <script type="application/ld+json">
    {JSON.stringify(structuredData)}
  </script>
  
  <!-- Page-specific head content -->
  <slot name="head" />
  <ViewTransitions />
</head>

<body>
  <div class="buwatv-bg-video" aria-hidden="true">
    <video autoplay muted loop playsinline preload="auto">
      <source src="/uploads/background/buwatv/background-main.webm" type="video/webm" />
      <source src="/uploads/background/buwatv/background-main.mp4" type="video/mp4" />
      <source src="/uploads/hero/0.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Header slot - pages provide their own header -->
  <slot name="header" />
  
  <!-- Main content -->
  <slot />
  
  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-menu-panel" id="buwatvFooterPanel">
      <span class="footer-menu-label">Menu</span>
      <nav class="footer-menu-links">
        <a href="/buwatv/">BuWa TV Home</a>
        <a href="/buwatv/pricing/">Pricing</a>
        <a href="/buwatv/locations/">Locations</a>
        <a href="/buwatv/faq/">FAQ</a>
        <a href="/buwatv/signup/">Sign Up</a>
        <a href="/" target="_self">BuWa Digital</a>
      </nav>
      <div class="footer-menu-legal">
        <a href="/buwatv/privacy/">Privacy Policy</a>
        <span>&middot;</span>
        <a href="/buwatv/terms/">Terms &amp; Conditions</a>
      </div>
    </div>
    <div class="footer-legal">
      <p>&copy; {currentYear} BuWa TV</p>
    </div>
  </footer>
</body>
</html>

<script is:inline>
  function bindBuwaTvScrollLinks() {
    document.querySelectorAll('.scroll-link').forEach((link) => {
      if (link.dataset.scrollBound === 'true') return;
      link.dataset.scrollBound = 'true';
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) {
            const headerOffset = 80;
            const elementPosition = target.getBoundingClientRect().top;
            const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

            window.scrollTo({
              top: offsetPosition,
              behavior: 'smooth'
            });

            const menuToggle = document.getElementById('buwatvMenuToggle');
            const menuPanel = document.getElementById('buwatvMenuPanel');
            if (menuPanel?.classList.contains('is-open')) {
              menuPanel.classList.remove('is-open');
              menuPanel.setAttribute('aria-hidden', 'true');
              menuToggle?.setAttribute('aria-expanded', 'false');
              menuToggle?.classList.remove('is-open');
              document.querySelector('.site-header')?.classList.remove('menu-open');
            }
          }
        }
      });
    });
  }

  function initBuwaTvHeaderMenu() {
    const menuToggle = document.getElementById('buwatvMenuToggle');
    const menuPanel = document.getElementById('buwatvMenuPanel');
    const siteHeader = document.querySelector('.site-header');
    const heroSection = document.querySelector('.hero, .page-hero');
    if (!menuToggle || !menuPanel || !siteHeader) return;
    if (menuToggle.dataset.bound === 'true') return;
    menuToggle.dataset.bound = 'true';

    const navFadeThreshold = 30;
    const controller = new AbortController();
    const { signal } = controller;

    document.addEventListener('astro:before-swap', () => {
      controller.abort();
      delete menuToggle.dataset.bound;
    }, { once: true });

    const closeHeaderMenu = () => {
      menuPanel.classList.remove('is-open');
      menuPanel.setAttribute('aria-hidden', 'true');
      menuToggle.setAttribute('aria-expanded', 'false');
      menuToggle.classList.remove('is-open');
      siteHeader.classList.remove('menu-open');
    };

    const syncHeaderState = () => {
      const headerH = siteHeader.getBoundingClientRect().height;
      let pastHero;
      if (heroSection) {
        const heroRect = heroSection.getBoundingClientRect();
        pastHero = window.scrollY > 20 && heroRect.bottom <= headerH + 8;
      } else {
        pastHero = window.scrollY > 40;
      }
      const scrolled = window.scrollY > navFadeThreshold;
      siteHeader.classList.toggle('after-hero', pastHero);
      siteHeader.classList.toggle('nav-hidden', scrolled);
      if (scrolled && menuPanel.classList.contains('is-open')) closeHeaderMenu();
    };

    syncHeaderState();
    window.addEventListener('scroll', syncHeaderState, { passive: true, signal });
    window.addEventListener('resize', syncHeaderState, { signal });

    menuToggle.addEventListener('click', () => {
      if (typeof window.__buwatvResetBottomMenu === 'function') {
        window.__buwatvResetBottomMenu();
      }
      const nextOpen = !menuPanel.classList.contains('is-open');
      menuPanel.classList.toggle('is-open', nextOpen);
      menuPanel.setAttribute('aria-hidden', nextOpen ? 'false' : 'true');
      menuToggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
      menuToggle.classList.toggle('is-open', nextOpen);
      siteHeader.classList.toggle('menu-open', nextOpen);
    }, { signal });

    menuPanel.addEventListener('click', (event) => {
      if (event.target === menuPanel) closeHeaderMenu();
    }, { signal });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeHeaderMenu();
    }, { signal });
  }

  document.addEventListener('astro:page-load', () => {
    bindBuwaTvScrollLinks();
    initBuwaTvHeaderMenu();

    const panel = document.getElementById('buwatvFooterPanel');
    if (!panel) return;

    let panelHeight = 0;
    let progress = 0; // 0 = hidden, 1 = fully revealed
    let touchStartY = 0;
    let touchActive = false;
    let lockBottom = false;

    const isAtPageBottom = () =>
      window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 2;

    const getPageBottomY = () =>
      Math.max(0, document.documentElement.scrollHeight - window.innerHeight);

    const measure = () => {
      const prevTransform = panel.style.transform;
      panel.style.transform = 'translate(-50%, 100%)';
      panelHeight = panel.offsetHeight || panelHeight || 1;
      panel.style.transform = prevTransform;
    };

    const applyProgress = () => {
      if (progress < 0.002) progress = 0;
      if (progress > 0.998) progress = 1;
      const hiddenPercent = (1 - progress) * 100;
      const hiddenOffsetPx = Math.round((1 - progress) * 16);
      panel.style.transform = `translate(-50%, calc(${hiddenPercent}% + ${hiddenOffsetPx}px))`;
      panel.classList.toggle('is-visible', progress > 0.001);
      lockBottom = progress > 0;
      if (lockBottom) {
        window.scrollTo(0, getPageBottomY());
      }
    };

    const resetBottomMenu = () => {
      progress = 0;
      lockBottom = false;
      applyProgress();
    };

    window.__buwatvResetBottomMenu = resetBottomMenu;

    const adjustProgress = (deltaY) => {
      if (!panelHeight) measure();
      const deltaProgress = Math.abs(deltaY) / Math.max(panelHeight, 1);
      if (deltaY > 0) progress = Math.min(1, progress + deltaProgress);
      else progress = Math.max(0, progress - deltaProgress);
      applyProgress();
    };

    const onWheel = (event) => {
      const deltaY = event.deltaY;
      const atBottom = isAtPageBottom();
      const captureWhileOpen = progress > 0;
      const captureDownAtBottom = deltaY > 0 && atBottom;
      if (!captureWhileOpen && !captureDownAtBottom) return;
      event.preventDefault();
      adjustProgress(deltaY);
    };

    const onTouchStart = (event) => {
      if (!event.touches || event.touches.length === 0) return;
      touchStartY = event.touches[0].clientY;
      touchActive = true;
    };

    const onTouchMove = (event) => {
      if (!touchActive || !event.touches || event.touches.length === 0) return;
      const currentY = event.touches[0].clientY;
      const deltaY = touchStartY - currentY;
      if (Math.abs(deltaY) < 2) return;
      const atBottom = isAtPageBottom();
      const captureWhileOpen = progress > 0;
      const captureDownAtBottom = deltaY > 0 && atBottom;
      if (!captureWhileOpen && !captureDownAtBottom) return;
      event.preventDefault();
      adjustProgress(deltaY);
      touchStartY = currentY;
    };

    const onTouchEnd = () => {
      touchActive = false;
    };

    const onScrollLock = () => {
      // Safety reset: if page has left the bottom region, fully close the panel state.
      if (!isAtPageBottom() && progress > 0) {
        progress = 0;
        applyProgress();
        return;
      }
      if (lockBottom) {
        window.scrollTo(0, getPageBottomY());
      }
    };

    measure();
    applyProgress();
    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('touchmove', onTouchMove, { passive: false });
    window.addEventListener('touchend', onTouchEnd, { passive: true });
    window.addEventListener('resize', measure);
    window.addEventListener('scroll', onScrollLock, { passive: true });
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('wheel', onWheel);
      window.removeEventListener('touchstart', onTouchStart);
      window.removeEventListener('touchmove', onTouchMove);
      window.removeEventListener('touchend', onTouchEnd);
      window.removeEventListener('resize', measure);
      window.removeEventListener('scroll', onScrollLock);
      try { delete window.__buwatvResetBottomMenu; } catch {}
    }, { once: true });
  });
</script>

<style is:global>
  /* Honeypot (fax field) - hidden from users, bots fill it; Tasklet ignores when populated */
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* Base reset for pages using this layout */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Montserrat', sans-serif;
    line-height: 1.6;
    background: #050914;
    color: #eaf3ff;
  }

  .buwatv-bg-video {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
    background: #050914;
  }

  .buwatv-bg-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.06) contrast(1.02) brightness(0.9);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', 'Inter', sans-serif;
    font-weight: 700;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .section-accent-bar::before {
    display: none;
  }

  /* BuWa TV shared header (BuWaTvSiteHeader) */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1600;
    background: transparent;
    border-bottom: 1px solid transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
    transition: background 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease, backdrop-filter 0.28s ease;
    --dropdown-bg: rgba(30, 30, 35, 0.84);
    --dropdown-border: rgba(255, 255, 255, 0.16);
    --dropdown-link: rgba(238, 246, 255, 0.92);
    --dropdown-hover-bg: rgba(255, 255, 255, 0.08);
    --dropdown-hover-color: #ffffff;
    --dropdown-shadow: 0 18px 48px rgba(4, 10, 22, 0.55);
  }

  .site-header.after-hero,
  .site-header.menu-open {
    background: rgba(30, 30, 35, 0.62);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.32);
    isolation: isolate;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 15px 40px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .header-logo {
    justify-self: start;
  }

  .header-logo img {
    height: 45px;
    width: auto;
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
    justify-self: end;
  }

  .main-nav {
    justify-self: center;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .site-header.nav-hidden .main-nav {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .site-header.nav-hidden .header-cta {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .menu-toggle {
    color: rgba(236, 245, 255, 0.96);
    border: none;
    border-radius: 0;
    width: min(90vw, 272px);
    height: 54px;
    padding: 0.5rem 1.15rem;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    font-family: inherit;
    background: transparent;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .menu-pill-label {
    text-transform: uppercase;
    letter-spacing: 0.11em;
    font-size: 0.84rem;
    font-weight: 400;
    text-align: center;
  }

  .menu-toggle.is-open {
    background: transparent;
  }

  .menu-toggle:hover {
    background: transparent;
    transform: translateY(-1px);
  }

  .menu-toggle:active {
    transform: translateY(0);
  }

  .menu-chevron {
    display: inline-block;
    margin-left: 0.35em;
    font-size: 0.78em;
    line-height: 1;
    vertical-align: middle;
    transition: transform 0.22s ease;
    opacity: 0.75;
  }

  .menu-toggle.is-open .menu-chevron {
    transform: rotate(180deg);
  }

  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 1605;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .menu-panel {
    position: fixed;
    top: 88px;
    left: 50%;
    transform: translateX(-50%);
    width: min(90vw, 360px);
    padding: 1.5rem 1.5rem 1.25rem;
    background: rgba(30, 30, 35, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    text-align: center;
  }

  .menu-panel-top {
    margin-bottom: 1rem;
  }

  .menu-title {
    color: #e8f2ff;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.6rem;
    font-weight: 500;
    opacity: 0.7;
  }

  .menu-nav-primary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .menu-item {
    display: block;
    color: transparent;
    text-decoration: none;
    padding: 0.35rem 0.5rem;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.2;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .menu-item-label {
    display: block;
    color: rgba(242, 248, 255, 0.85);
    transform: translateY(0);
    opacity: 1;
    transition: transform 0.22s ease, opacity 0.22s ease;
  }

  .menu-item::after {
    content: attr(data-roll-label);
    position: absolute;
    inset: 0;
    display: block;
    padding: 0.35rem 0.5rem;
    text-align: center;
    font-size: inherit;
    font-weight: inherit;
    line-height: 1.2;
    color: rgba(210, 224, 245, 0.45);
    transform: translateY(115%);
    opacity: 0;
    transition: transform 0.22s ease, opacity 0.22s ease;
    pointer-events: none;
  }

  .menu-nav-primary:has(.menu-item:hover) .menu-item .menu-item-label {
    transform: translateY(-115%);
    opacity: 0;
  }

  .menu-nav-primary:has(.menu-item:hover) .menu-item::after {
    transform: translateY(0);
    opacity: 1;
  }

  .menu-nav-primary:has(.menu-item:hover) .menu-item:hover .menu-item-label {
    transform: translateY(0);
    opacity: 1;
  }

  .menu-nav-primary:has(.menu-item:hover) .menu-item:hover::after {
    transform: translateY(115%);
    opacity: 0;
  }

  .header-cta {
    text-decoration: none;
    background: #fff;
    color: #102043;
    border-radius: 999px;
    padding: 0.58rem 0.95rem;
    font-size: 0.73rem;
    font-weight: 700;
    transform: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  @media (max-width: 992px) {
    .header-cta {
      display: inline-flex;
    }
  }

  @media (max-width: 768px) {
    .header-cta {
      display: none;
    }

    .header-container {
      padding: 12px 20px;
      grid-template-columns: auto 1fr auto;
      gap: 0.5rem;
    }

    .main-nav {
      justify-self: center;
    }

    .menu-toggle {
      width: 54px;
      min-width: 54px;
      height: 46px;
      padding: 0;
      position: relative;
      justify-content: center;
    }

    .menu-pill-label {
      font-size: 0;
      letter-spacing: 0;
      opacity: 0;
      width: 0;
      overflow: hidden;
      pointer-events: none;
    }

    .menu-chevron {
      display: none;
    }

    .menu-toggle::before,
    .menu-toggle::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 50%;
      width: 20px;
      height: 2px;
      border-radius: 99px;
      background: rgba(235, 245, 255, 0.95);
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .menu-toggle::before {
      transform: translate(-50%, -50%);
      box-shadow: 0 -6px 0 rgba(235, 245, 255, 0.95), 0 6px 0 rgba(235, 245, 255, 0.95);
    }

    .menu-toggle::after {
      transform: translate(-50%, -50%) rotate(-45deg);
      opacity: 0;
    }

    .menu-toggle.is-open::before {
      box-shadow: none;
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .menu-toggle.is-open::after {
      opacity: 1;
    }

    .menu-panel {
      width: min(92vw, 340px);
      top: 74px;
    }
  }

  .site-footer {
    background: transparent;
    color: #fff;
    padding: 1.25rem 1.25rem calc(1.25rem + env(safe-area-inset-bottom));
    position: relative;
  }

  .footer-menu-panel {
    position: fixed;
    left: 50%;
    bottom: calc(16px + env(safe-area-inset-bottom));
    transform: translate(-50%, 100%);
    width: min(90vw, 360px);
    padding: 1.5rem 1.5rem 1.25rem;
    border-radius: 14px;
    background: rgba(30, 30, 35, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    text-align: center;
    will-change: transform;
    pointer-events: none;
    z-index: 980;
  }

  .footer-menu-panel.is-visible {
    pointer-events: auto;
  }

  .footer-menu-label {
    display: block;
