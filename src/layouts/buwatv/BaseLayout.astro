---
// BaseLayout.astro - Shared layout for BuWa TV pages
// Provides common head elements, footer, and slots for page content
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  ogType?: string;
}

const { title, description, canonical, image, imageAlt, noindex, ogType } = Astro.props;
const baseUrl = Astro.site ?? Astro.url;
const buwaTvUrl = new URL('/buwatv/', baseUrl).toString();
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, baseUrl).toString();
const defaultImage = '/uploads/logos/buwa-tv-dark.png';
const imageUrl = new URL(image ?? defaultImage, baseUrl).toString();
const imageAltText = imageAlt ?? 'BuWa TV indoor digital billboards';
const globalNoindex = import.meta.env.PUBLIC_BUWATV_NOINDEX === 'true';
const shouldNoindex = noindex || globalNoindex;
const robotsContent = shouldNoindex ? 'noindex, nofollow' : 'index, follow';
const ogTypeValue = ogType ?? 'website';
const currentYear = new Date().getFullYear();
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'BuWa TV',
      url: buwaTvUrl,
      logo: new URL('/uploads/logos/buwa-tv-dark.png', baseUrl).toString(),
      sameAs: [
        'https://www.youtube.com/@BuWadigital',
        'https://www.facebook.com/BuWaDigital',
        'https://www.instagram.com/buwadigital'
      ]
    },
    {
      '@type': 'WebSite',
      name: 'BuWa TV',
      url: buwaTvUrl
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content={robotsContent}>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="alternate" hreflang="en-US" href={canonicalUrl}>
  <link rel="alternate" hreflang="x-default" href={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogTypeValue}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:image" content={imageUrl}>
  <meta property="og:image:alt" content={imageAltText}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/png">
  <meta property="og:site_name" content="BuWa TV">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={imageUrl}>
  <meta name="twitter:image:alt" content={imageAltText}>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600&family=Outfit:wght@600;700&display=swap" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  
  <!-- Plausible Analytics -->
  <script async src="https://plausible.io/js/pa-G2ckSejgBZ8fG_9U33pzh.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>

  <!-- Structured data -->
  <script type="application/ld+json">
    {JSON.stringify(structuredData)}
  </script>
  
  <!-- Page-specific head content -->
  <slot name="head" />
  <ViewTransitions />
</head>

<body>
  <div class="buwatv-bg-video" aria-hidden="true">
    <video autoplay muted loop playsinline preload="auto">
      <source src="/uploads/background/buwatv/background-main.webm" type="video/webm" />
      <source src="/uploads/background/buwatv/background-main.mp4" type="video/mp4" />
      <source src="/uploads/hero/0.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Header slot - pages provide their own header -->
  <slot name="header" />
  
  <!-- Main content -->
  <slot />
  
  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-menu-panel" id="buwatvFooterPanel">
      <span class="footer-menu-label">Menu</span>
      <nav class="footer-menu-links">
        <a href="/buwatv/">BuWa TV Home</a>
        <a href="/buwatv/pricing/">Pricing</a>
        <a href="/buwatv/locations/">Locations</a>
        <a href="/buwatv/faq/">FAQ</a>
        <a href="/buwatv/signup/">Sign Up</a>
        <a href="/" target="_self">BuWa Digital</a>
      </nav>
      <div class="footer-menu-legal">
        <a href="/buwatv/privacy/">Privacy Policy</a>
        <span>&middot;</span>
        <a href="/buwatv/terms/">Terms &amp; Conditions</a>
      </div>
    </div>
    <div class="footer-legal">
      <p>&copy; {currentYear} BuWa TV</p>
    </div>
  </footer>
</body>
</html>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const panel = document.getElementById('buwatvFooterPanel');
    if (!panel) return;

    let panelHeight = 0;
    let progress = 0; // 0 = hidden, 1 = fully revealed
    let touchStartY = 0;
    let touchActive = false;

    const isAtPageBottom = () =>
      window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 2;

    const measure = () => {
      const prevTransform = panel.style.transform;
      panel.style.transform = 'translate(-50%, 100%)';
      panelHeight = panel.offsetHeight || panelHeight || 1;
      panel.style.transform = prevTransform;
    };

    const applyProgress = () => {
      const hiddenPercent = (1 - progress) * 100;
      panel.style.transform = `translate(-50%, ${hiddenPercent}%)`;
      panel.classList.toggle('is-visible', progress > 0.001);
    };

    const adjustProgress = (deltaY) => {
      if (!panelHeight) measure();
      const deltaProgress = Math.abs(deltaY) / Math.max(panelHeight, 1);
      if (deltaY > 0) progress = Math.min(1, progress + deltaProgress);
      else progress = Math.max(0, progress - deltaProgress);
      applyProgress();
    };

    const onWheel = (event) => {
      const deltaY = event.deltaY;
      const atBottom = isAtPageBottom();
      const captureDown = deltaY > 0 && (atBottom || progress > 0);
      const captureUp = deltaY < 0 && progress > 0;
      if (!captureDown && !captureUp) return;
      event.preventDefault();
      adjustProgress(deltaY);
    };

    const onTouchStart = (event) => {
      if (!event.touches || event.touches.length === 0) return;
      touchStartY = event.touches[0].clientY;
      touchActive = true;
    };

    const onTouchMove = (event) => {
      if (!touchActive || !event.touches || event.touches.length === 0) return;
      const currentY = event.touches[0].clientY;
      const deltaY = touchStartY - currentY;
      if (Math.abs(deltaY) < 2) return;
      const atBottom = isAtPageBottom();
      const captureDown = deltaY > 0 && (atBottom || progress > 0);
      const captureUp = deltaY < 0 && progress > 0;
      if (!captureDown && !captureUp) return;
      event.preventDefault();
      adjustProgress(deltaY);
      touchStartY = currentY;
    };

    const onTouchEnd = () => {
      touchActive = false;
    };

    measure();
    applyProgress();
    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('touchmove', onTouchMove, { passive: false });
    window.addEventListener('touchend', onTouchEnd, { passive: true });
    window.addEventListener('resize', measure);
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('wheel', onWheel);
      window.removeEventListener('touchstart', onTouchStart);
      window.removeEventListener('touchmove', onTouchMove);
      window.removeEventListener('touchend', onTouchEnd);
      window.removeEventListener('resize', measure);
    }, { once: true });
  });
</script>

<style is:global>
  /* Honeypot (fax field) - hidden from users, bots fill it; Tasklet ignores when populated */
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* Base reset for pages using this layout */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Montserrat', sans-serif;
    line-height: 1.6;
    background: #050914;
    color: #eaf3ff;
  }

  .buwatv-bg-video {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
    background: #050914;
  }

  .buwatv-bg-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.06) contrast(1.02) brightness(0.9);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', 'Inter', sans-serif;
    font-weight: 700;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .section-accent-bar::before {
    display: none;
  }

  .site-footer {
    background: transparent;
    color: #fff;
    padding: 1.25rem 1.25rem calc(1.25rem + env(safe-area-inset-bottom));
    position: relative;
  }

  .footer-menu-panel {
    position: fixed;
    left: 50%;
    bottom: calc(16px + env(safe-area-inset-bottom));
    transform: translate(-50%, 100%);
    width: min(90vw, 360px);
    padding: 1.5rem 1.5rem 1.25rem;
    border-radius: 14px;
    background: rgba(30, 30, 35, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    text-align: center;
    will-change: transform;
    pointer-events: none;
    z-index: 980;
  }

  .footer-menu-panel.is-visible {
    pointer-events: auto;
  }

  .footer-menu-label {
    display: block;
    margin-bottom: 0.9rem;
    color: #e8f2ff;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.6rem;
    opacity: 0.72;
  }

  .footer-menu-links {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .footer-menu-links a {
    color: rgba(242, 248, 255, 0.86);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 0.28rem 0;
  }

  .footer-menu-links a:hover {
    color: #fff;
  }

  .footer-menu-legal {
    margin-top: 0.7rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .footer-menu-legal a,
  .footer-menu-legal span {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.68rem;
  }

  .footer-menu-legal a:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .footer-legal p {
    color: rgba(255, 255, 255, 0.56);
    font-size: 0.72rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 20px;
    }
  }
</style>
