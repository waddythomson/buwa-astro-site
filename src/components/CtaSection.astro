---
interface Props {
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title,
  subtitle,
  buttonText = 'Get In Touch',
  buttonHref = '/contact-us/',
} = Astro.props;
---

<section class="cta-video-section">
  <div class="cta-video-shell" aria-hidden="true">
    <video class="cta-video-bg" autoplay muted loop playsinline preload="metadata">
      <source src="/uploads/new/hero/abstract/abstract-blue-1.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="cta-video-content">
    <h2>{title}</h2>
    {subtitle && <p>{subtitle}</p>}
    <a href={buttonHref} class="btn-red"><i class="fa-solid fa-paper-plane"></i> {buttonText}</a>
  </div>
</section>

<style>
  .cta-video-section {
    position: relative;
    overflow: hidden;
    padding: 4rem 2rem;
    text-align: center;
    color: white;
  }

  .cta-video-shell {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta-video-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cta-video-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-video-content h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: white;
  }

  .cta-video-content p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-video-content .btn-red {
    display: inline-block;
    background: #a01c2b;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .cta-video-content .btn-red:hover {
    background: #7d1521;
  }

  @media (max-width: 768px) {
    .cta-video-section {
      padding: 3rem 1.5rem;
    }

    .cta-video-content h2 {
      font-size: 1.5rem;
    }
  }
</style>
