---
interface Props {
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title,
  subtitle,
  buttonText = "Let's Talk!",
  buttonHref = '/contact-us/',
} = Astro.props;
---

<section class="cta-video-section">
  <div class="cta-video-shell" aria-hidden="true">
    <video class="cta-video-bg" autoplay muted loop playsinline preload="metadata">
      <source src="/uploads/new/hero/abstract/abstract-blue-1.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="cta-video-content">
    <h2>{title}</h2>
    {subtitle && <p class="cta-subtitle">{subtitle}</p>}
    <a href={buttonHref} class="btn-red">
      <i class="fa-solid fa-paper-plane"></i> {buttonText}
    </a>
  </div>
</section>

<style>
  .cta-video-section {
    position: relative;
    overflow: hidden;
    padding: 5rem 2rem;
    text-align: center;
  }

  .cta-video-shell {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta-video-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cta-video-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-video-content h2 {
    font-size: 2.2rem;
    color: #fff;
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
  }
</style>
